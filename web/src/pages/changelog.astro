---
import Base from '../layouts/Base.astro';
import { readChangelog } from '../lib/changelog.js';

// Real entries, read at BUILD TIME from the repo's CHANGELOG.md (Keep a
// Changelog format). Shows the most recent releases. No daemon, no network —
// pure file read. Honest + sourced: every line below exists in CHANGELOG.md.
const { ok, releases, error } = readChangelog(8);
---
<Base title="Changelog" description="Every release of ArchHub, sourced straight from the repo's CHANGELOG.md at build time.">

  <!-- ════════ HEADER ════════ -->
  <section class="lhead">
    <div class="wrap">
      <div class="eyebrow">● Changelog</div>
      <h1 class="title serif">Plotted on Friday,<br/><span class="ital">not promised.</span></h1>
      <p class="lede">The most recent ArchHub releases, generated at build time from <code>CHANGELOG.md</code> — the repo's single changelog. Every line below exists in the source tree; nothing here is hand-typed for the website.</p>
    </div>
  </section>

  <!-- ════════ ENTRIES ════════ -->
  <section class="sec wrap">
    {!ok && (
      <p class="note mono">Changelog source unavailable: {error}</p>
    )}

    {ok && releases.length === 0 && (
      <p class="note mono">No releases parsed from CHANGELOG.md yet.</p>
    )}

    {ok && releases.map((rel) => (
      <article class="rel">
        <div class="rel-head">
          <span class="ver-tag">v{rel.version}</span>
          <span class="rel-rule"></span>
          <span class="rel-date mono">{rel.date}</span>
        </div>
        {rel.sections.map((sec) => (
          <div class="grp">
            <h3>{sec.heading}</h3>
            <ul>
              {sec.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        ))}
      </article>
    ))}

    <p class="note mono" style="margin-top:40px;">
      Showing the {releases.length} most recent releases · full history in CHANGELOG.md ·
      <a class="ilink" href="https://github.com/Fargaly/ArchHub/releases" rel="noopener">all releases on GitHub →</a>
    </p>
  </section>

  <style>
    .sec { padding: var(--sp-6xl) 0; }
    .lhead { padding: var(--sp-7xl) 0 var(--sp-5xl); border-bottom: 1px solid var(--line-soft);
      background-image: radial-gradient(var(--line-soft) 1px, transparent 1px); background-size: 22px 22px; }
    h1.title { font-size: var(--fs-d2); line-height: 1; letter-spacing: -0.035em; margin: 14px 0 0; }
    .lede { font-family: var(--serif); font-size: var(--fs-h2); font-style: italic; color: var(--ink-soft);
      letter-spacing: -0.01em; line-height: 1.38; margin-top: var(--sp-xl); max-width: 640px; }
    .lede code { font-family: var(--mono); font-size: 14px; color: var(--accent); font-style: normal; }

    .rel { padding: 0 0 var(--sp-4xl); margin-bottom: var(--sp-4xl); border-bottom: 1px solid var(--line-soft); }
    .rel:last-of-type { border-bottom: 0; }
    .rel-head { display: flex; align-items: center; gap: 16px; margin-bottom: 22px; }
    .ver-tag { font-family: var(--serif); font-size: 34px; color: var(--ink); letter-spacing: -0.02em; }
    .rel-rule { flex: 1; height: 1px; background: var(--line); }
    .rel-date { font-size: 12px; color: var(--ink-muted); letter-spacing: 0.06em; }

    .grp { margin: 0 0 22px; }
    .grp h3 { font-family: var(--mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--accent); margin: 0 0 12px; font-weight: 400; }
    .grp ul { list-style: none; padding: 0; margin: 0; }
    .grp li { position: relative; padding: 7px 0 7px 22px; font-size: 14px; color: var(--ink-soft);
      line-height: 1.55; border-top: 1px solid var(--line-soft); }
    .grp li:first-child { border-top: 0; }
    .grp li::before { content: "◇"; position: absolute; left: 0; top: 7px; color: var(--accent); font-size: 11px; }

    .note { font-size: 11px; color: var(--ink-muted); letter-spacing: 0.06em; }
    .ilink { color: var(--accent); font-weight: 500; letter-spacing: 0; }
    .ilink:hover { color: var(--accent-hi); }

    @media (max-width: 820px) {
      h1.title { font-size: 42px; }
      .ver-tag { font-size: 28px; }
    }
  </style>
</Base>
