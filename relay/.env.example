# ArchHub Cloud Relay — required environment variables.
# Copy to .env.local for `vercel dev`, or paste each into the Vercel
# project's Environment Variables panel for production.

# --- Supabase ---------------------------------------------------------------
# Project URL and the public anon key. The anon key is safe to expose.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...PUBLIC_ANON_KEY...

# Service-role key. NEVER expose to clients. The relay uses it for
# usage logging + firm-key lookup only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...SERVICE_ROLE...

# --- Optional: per-relay-instance defaults ---------------------------------
# These are only used by `scripts/seed-test-firm.ts` and any future
# default-firm bootstrap path. Production firm keys live in the
# `firms.*_key_encrypted` columns, NOT here.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# --- Tuning ---------------------------------------------------------------
# Per-user requests per minute, in-memory token bucket.
RELAY_RATE_PER_MIN=60
