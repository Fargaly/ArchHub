/* ArchHub theme — glass morphism on a warm dark canvas.
   Translucent panels, layered surfaces, soft inner highlights, no hard
   borders. Qt6's QSS doesn't support real CSS backdrop-filter, so the
   "frosted" feel is achieved with semi-transparent fills, gradient
   surfaces, and 1px highlight strokes. The main window paints a
   gradient background; everything above floats over it.
*/

/* ── Base canvas: warm dark with subtle vertical gradient ─────────────── */
QMainWindow, QWidget#centralWidget, QWidget {
    background-color: #14141a;
    color: #f4efe8;
    font-family: "Inter", "Segoe UI", -apple-system, sans-serif;
}

QMainWindow {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0    #221c2a,
        stop:0.35 #18161e,
        stop:0.7  #14121a,
        stop:1    #100e16
    );
}

/* ── Header — frosted strip, translucent over the gradient ────────────── */
QFrame#header {
    background-color: rgba(28, 28, 36, 0.72);
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}
QLabel#brand {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.4px;
    color: #f4efe8;
    padding-left: 4px;
}

/* Model picker — frosted glass tile */
QComboBox#modelPicker {
    background-color: rgba(255, 255, 255, 0.04);
    color: #f4efe8;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 8px 16px;
    min-width: 240px;
    font-size: 13px;
}
QComboBox#modelPicker:hover {
    background-color: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
}
QComboBox#modelPicker:focus { border-color: #cc785c; }
QComboBox#modelPicker::drop-down { border: none; width: 18px; }
QComboBox QAbstractItemView {
    background-color: rgba(28, 28, 36, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.08);
    selection-background-color: rgba(204, 120, 92, 0.25);
    padding: 4px;
    outline: 0;
}

/* Single menu cog */
QToolButton#menuButton {
    background-color: rgba(255, 255, 255, 0.04);
    color: #d8d6d0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    font-size: 16px;
}
QToolButton#menuButton:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.14);
    color: #f4efe8;
}
QToolButton#menuButton::menu-indicator { image: none; width: 0px; }

/* App menu — floating frosted panel */
QMenu#appMenu, QMenu {
    background-color: rgba(28, 28, 36, 0.97);
    color: #e8e3dc;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 6px;
    font-size: 13px;
}
QMenu#appMenu::item, QMenu::item {
    padding: 8px 18px 8px 14px;
    border-radius: 8px;
    margin: 1px 2px;
    min-width: 220px;
}
QMenu#appMenu::item:selected, QMenu::item:selected {
    background-color: rgba(204, 120, 92, 0.18);
    color: #f4efe8;
}
QMenu#appMenu::separator, QMenu::separator {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 4px 8px;
}

/* ── Conversation area — transparent so the gradient bg shows ────────── */
QScrollArea#conversationScroll, QScrollArea#conversationScroll > QWidget > QWidget {
    background: transparent;
    border: none;
}

/* Welcome card — large frosted slab */
QFrame#welcomeCard {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 22px;
}
QLabel#welcomeTitle {
    font-size: 28px;
    font-weight: 600;
    color: #f4efe8;
    letter-spacing: -0.2px;
}
QLabel#welcomeSubtitle {
    font-size: 13px;
    color: #b0aaa1;
    line-height: 1.6;
}

/* Quick-start chips on welcome card — small frosted tiles */
QPushButton#welcomeChip {
    background-color: rgba(255, 255, 255, 0.04);
    color: #e8e3dc;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 12px 16px;
    font-size: 12px;
    text-align: left;
}
QPushButton#welcomeChip:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(204, 120, 92, 0.30);
    color: #f4efe8;
}

/* ── Chat bubbles — frosted glass with asymmetric corners ─────────────── */
QFrame#userBubble {
    background-color: rgba(204, 120, 92, 0.16);
    border: 1px solid rgba(204, 120, 92, 0.32);
    border-radius: 20px;
    border-bottom-right-radius: 6px;
}
QFrame#assistantBubble {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    border-bottom-left-radius: 6px;
}

/* Typing indicator inside an assistant bubble while LLM is thinking */
QLabel#typingIndicator {
    color: rgba(244, 239, 232, 0.45);
    font-size: 18px;
    letter-spacing: 4px;
    padding: 2px 4px;
}
QTextEdit#messageText {
    background-color: transparent;
    color: #f4efe8;
    border: none;
    font-size: 14px;
    line-height: 1.55;
}

/* ── Tool cards — sub-frosted with darker fill so they read as nested ─ */
QFrame#toolCard {
    background-color: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
}
QFrame#toolCard:hover { border-color: rgba(255, 255, 255, 0.12); }
QLabel#toolCardTitle  { color: #d6d4d0; font-size: 12px; font-weight: 500; }
QLabel#toolCardStatus { color: #8a8580; font-size: 11px; }
QToolButton#toolCardChevron {
    background-color: transparent;
    color: #7a7782;
    border: none;
    font-size: 12px;
}
QTextEdit#toolCardDetail {
    background-color: rgba(0, 0, 0, 0.45);
    color: #c4c0b9;
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 10px;
    font-family: "Cascadia Mono", "Consolas", monospace;
    font-size: 11px;
}

/* ── Input bar — large frosted footer ─────────────────────────────────── */
QFrame#inputBar {
    background-color: rgba(28, 28, 36, 0.65);
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
}
QLineEdit#inputField {
    background-color: rgba(255, 255, 255, 0.04);
    color: #f4efe8;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 16px;
    padding: 13px 18px;
    font-size: 14px;
}
QLineEdit#inputField:hover {
    background-color: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.16);
}
QLineEdit#inputField:focus {
    border-color: rgba(204, 120, 92, 0.65);
    background-color: rgba(255, 255, 255, 0.06);
}

/* ── Status bar — thin tinted strip ───────────────────────────────────── */
QFrame#statusBar {
    background-color: rgba(0, 0, 0, 0.25);
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
}
QLabel#statusText { color: #8a8580; font-size: 11px; }

/* ── Buttons ──────────────────────────────────────────────────────────── */
QPushButton#primaryButton {
    background-color: #cc785c;
    color: #1a1a1c;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 12px;
    padding: 10px 22px;
    font-weight: 600;
    font-size: 13px;
}
QPushButton#primaryButton:hover  {
    background-color: #d68872;
}
QPushButton#primaryButton:pressed { background-color: #b8654a; }
QPushButton#primaryButton:disabled {
    background-color: rgba(204, 120, 92, 0.20);
    color: rgba(244, 239, 232, 0.40);
    border-color: rgba(255, 255, 255, 0.04);
}

QPushButton#dangerButton {
    background-color: rgba(180, 60, 50, 0.20);
    color: #f4efe8;
    border: 1px solid rgba(180, 60, 50, 0.45);
    border-radius: 12px;
    padding: 10px 22px;
    font-size: 13px;
}
QPushButton#dangerButton:hover {
    background-color: rgba(180, 60, 50, 0.30);
}

QPushButton#ghostButton {
    background-color: rgba(255, 255, 255, 0.04);
    color: #d6d4d0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 8px 16px;
    font-size: 12px;
}
QPushButton#ghostButton:hover {
    background-color: rgba(255, 255, 255, 0.08);
    color: #f4efe8;
    border-color: rgba(255, 255, 255, 0.14);
}

/* ── Settings dialog ──────────────────────────────────────────────────── */
QDialog#settingsDialog, QDialog#panel {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #1a1a22,
        stop:1 #14141a
    );
}
QLabel#settingsTitle { font-size: 22px; font-weight: 600; color: #f4efe8; }
QLabel#settingsSubtitle { color: #a09a90; font-size: 12px; line-height: 1.5; }

/* Settings + provider rows — frosted tiles */
QFrame#providerRow {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
}
QFrame#providerRow:hover {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.12);
}
QLabel#providerName   { font-size: 13px; font-weight: 500; color: #f4efe8; }
QLabel#providerStatus { font-size: 12px; color: #a09a90; }
QLabel#providerIcon   {
    color: #cc785c;
    font-size: 14px;
    font-weight: 700;
    min-width: 16px;
}

/* ── Generic panels (Connectors / Skills / Update) ─────────────────────── */
QFrame#panelHeader {
    background-color: rgba(255, 255, 255, 0.02);
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}
QLabel#panelTitle { font-size: 22px; font-weight: 600; color: #f4efe8; }
QLabel#panelSubtitle { font-size: 13px; color: #a09a90; }
QFrame#panelFooter {
    background-color: rgba(0, 0, 0, 0.20);
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
}

QFrame#connectorRow {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
}
QFrame#connectorRow:hover {
    background-color: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.14);
}
QLabel#connectorIcon {
    background-color: rgba(255, 255, 255, 0.08);
    color: #f4efe8;
    font-size: 16px;
    font-weight: 600;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.10);
}
QLabel#connectorName { font-size: 14px; font-weight: 500; }
QLabel#connectorStatus { font-size: 12px; color: #a09a90; }

/* ── Scrollbars ────────────────────────────────────────────────────────── */
QScrollBar:vertical {
    background-color: transparent;
    width: 10px;
    margin: 4px 0;
}
QScrollBar::handle:vertical {
    background-color: rgba(255, 255, 255, 0.10);
    border-radius: 5px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover { background-color: rgba(255, 255, 255, 0.20); }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical { background: transparent; }

/* ── Parameters sidebar ────────────────────────────────────────────────── */
QWidget#paramsPanel {
    background-color: rgba(0, 0, 0, 0.25);
    border-left: 1px solid rgba(255, 255, 255, 0.04);
}
QFrame#paramsPanelHeader {
    background-color: transparent;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}
QLabel#paramsPanelTitle { font-size: 15px; font-weight: 600; color: #f4efe8; }
QLabel#paramsPanelSubtitle { font-size: 11px; color: #6e6c75; }
QLabel#paramsPanelEmpty { color: #6e6c75; font-size: 12px; padding: 32px 24px; }

QFrame#paramRow {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
}
QFrame#paramRow:hover { border-color: rgba(255, 255, 255, 0.12); }
QLabel#paramLabel { font-size: 12px; font-weight: 500; color: #d6d4d0; }
QLabel#paramMeta  { font-size: 10px; color: #6e6c75; }
QLabel#paramReadonly {
    font-size: 11px;
    color: #a09a90;
    font-family: "Cascadia Mono", "Consolas", monospace;
}

/* Sliders */
QSlider::groove:horizontal {
    height: 3px;
    background: rgba(255, 255, 255, 0.10);
    border-radius: 1px;
}
QSlider::handle:horizontal {
    background: #cc785c;
    width: 16px;
    height: 16px;
    margin: -7px 0;
    border-radius: 8px;
    border: 2px solid rgba(255, 255, 255, 0.18);
}
QSlider::handle:horizontal:hover { background: #d68872; }
QSlider::sub-page:horizontal { background: #cc785c; border-radius: 1px; }

/* Inline numeric inputs */
QDoubleSpinBox, QSpinBox, QLineEdit, QComboBox {
    background-color: rgba(255, 255, 255, 0.04);
    color: #f4efe8;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 8px;
    padding: 5px 9px;
    font-size: 12px;
}
QDoubleSpinBox:focus, QSpinBox:focus, QLineEdit:focus, QComboBox:focus {
    border-color: rgba(204, 120, 92, 0.55);
    background-color: rgba(255, 255, 255, 0.06);
}
QComboBox::drop-down { border: 0; width: 18px; }

/* ── Skills panel — tabs ──────────────────────────────────────────────── */
QTabWidget#skillsTabs::pane {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    margin-top: -1px;
    background-color: rgba(255, 255, 255, 0.02);
}
QTabWidget#skillsTabs QTabBar::tab {
    background-color: transparent;
    color: #8a8580;
    padding: 10px 24px;
    margin-right: 2px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: none;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    font-size: 13px;
}
QTabWidget#skillsTabs QTabBar::tab:selected {
    background-color: rgba(255, 255, 255, 0.04);
    color: #f4efe8;
}

/* Skills panel — frosted cards */
QFrame#skillCard {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
}
QFrame#skillCard:hover {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: rgba(204, 120, 92, 0.30);
}
QLabel#skillCardTitle    { font-size: 15px; font-weight: 600; color: #f4efe8; }
QLabel#skillCardIntent   { color: #c4c0b9; font-size: 13px; line-height: 1.5; }
QLabel#skillCardTags     {
    color: #cc785c;
    font-size: 10px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    font-weight: 600;
}
QLabel#skillCardSection  { color: #7a7782; font-size: 11px; margin-top: 4px; }
QLabel#skillCardExample  { color: #aaa49a; font-size: 12px; font-style: italic; }
QLabel#skillCardStats    { color: #7a7782; font-size: 11px; }
QLabel#skillCardBadge    {
    color: #a09a90;
    font-size: 10px;
    padding: 3px 10px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 9px;
    background-color: rgba(255, 255, 255, 0.03);
}
QLabel#panelEmptyState   {
    color: #a09a90;
    font-size: 13px;
    padding: 28px;
    text-align: center;
}

/* Skill suggestion in chat */
QFrame#skillSuggestionRow { background: transparent; }

/* Update dialog */
QLabel#updateStatus { font-size: 14px; font-weight: 600; color: #f4efe8; }
QLabel#updateDetail { font-size: 12px; color: #b9b3a9; line-height: 1.5; }

/* Checkboxes + radio buttons */
QCheckBox, QRadioButton {
    color: #d6d4d0;
    spacing: 10px;
    font-size: 13px;
}
QCheckBox::indicator, QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background-color: rgba(255, 255, 255, 0.04);
    border-radius: 5px;
}
QRadioButton::indicator { border-radius: 9px; }
QCheckBox::indicator:hover, QRadioButton::indicator:hover {
    border-color: rgba(204, 120, 92, 0.65);
}
QCheckBox::indicator:checked, QRadioButton::indicator:checked {
    background-color: #cc785c;
    border-color: #cc785c;
}

/* ── Welcome chip rendering preserves QPushButton typography ─────────── */
QPushButton { font-family: "Inter", "Segoe UI", -apple-system, sans-serif; }

/* Tooltips — frosted */
QToolTip {
    background-color: rgba(28, 28, 36, 0.97);
    color: #e8e3dc;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 11px;
}
