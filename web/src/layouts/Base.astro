---
// Shared layout — every page imports this. Carries the canonical ArchHub
// design language: terracotta accent #d97757, the bg/ink/line ramps,
// Instrument Serif (display) + Inter (body) + JetBrains Mono (data) +
// Architects Daughter (wordmark). These :root values MIRROR tokens.jsx
// (window.AH), the project source of truth — see the design handoff README:
// CSS can't import the JS tokens, so this is the one hand-synced copy. To
// change a value, change tokens.jsx, then mirror it here.
//
// The freshness footer is stamped at BUILD TIME from the committed
// src/data/build-info.json (git sha + date) — regenerate with
// `npm run refresh-content`.
import buildInfo from '../data/build-info.json';
const { title, description } = Astro.props;
// SEO: avoid the "X — ArchHub — ArchHub" double when a page title already
// carries the brand (the home title does); canonical + OG/Twitter cards.
const fullTitle = (title && title.includes('ArchHub')) ? title : `${title} — ArchHub`;
const desc = description ?? "The graph-first AI workspace for architects, engineers, and contractors. One canvas, every host you already use, wired together. Local-first.";
const canonical = new URL(Astro.url.pathname, 'https://archhub.io').href;
const ogImage = 'https://archhub.io/og.svg';
const sha = buildInfo.git_sha ?? 'unknown';
const builtDate = (buildInfo.git_date ?? '').slice(0, 10) || 'unknown';
const connectors = buildInfo.connectors ?? 0;
const operations = buildInfo.operations ?? 0;
const path = Astro.url.pathname;
const isActive = (href) => href === '/' ? path === '/' : path.startsWith(href);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#d97757" />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ArchHub" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&family=Architects+Daughter&display=swap" rel="stylesheet" />
    <!-- is:global — Base defines the SHARED design language (canonical tokens +
         utility classes like .serif/.ital/.eyebrow/.btn/.wrap/.dim + nav +
         footer) consumed by every page. Without is:global, Astro scopes these
         to Base's own cid and the page elements that use them (e.g. the hero's
         .serif .ital headline) fall back to Inter/normal — a visual regression
         off the signed prototype. Page-specific styles stay scoped per page. -->
    <style is:global>
      :root {
        /* Canonical values mirror tokens.jsx (window.AH) — the source of truth. */
        --bg: #0e0e11; --bg-panel: #15151a; --bg-soft: #1c1c23; --bg-deep: #0a0a0d; --bg-ink: #18181e;
        --ink: #ece8e0; --ink-soft: #9b938a; --ink-muted: #5e574f; --ink-dim: #3a3530;
        --line: #26262e; --line-soft: #1e1e24; --line-hair: #1a1a20;
        --accent: #d97757; --accent-soft: #3a2018; --accent-hi: #e8896a;
        --ok: #7ec18e; --warn: #e5b25a; --err: #e6705f; --cyan: #5fb3b3; --purple: #a98cd6; --blue: #7898d6;
        --serif: 'Instrument Serif', Georgia, serif;
        --sans: 'Inter', system-ui, sans-serif;
        --mono: 'JetBrains Mono', ui-monospace, monospace;
        --arch: 'Architects Daughter', 'Comic Sans MS', cursive;
        --page: 1240px;
        /* spacing scale · mirrors BB.sp (4px base) */
        --sp-xs: 4px; --sp-sm: 8px; --sp-md: 12px; --sp-lg: 16px; --sp-xl: 24px;
        --sp-2xl: 32px; --sp-3xl: 40px; --sp-4xl: 48px; --sp-5xl: 56px; --sp-6xl: 72px; --sp-7xl: 96px;
        /* radius scale · mirrors BB.rad */
        --r-xs: 3px; --r-sm: 5px; --r-md: 6px; --r-lg: 8px; --r-xl: 10px; --r-pill: 999px;
        /* type scale · mirrors BB.fs (size) */
        --fs-d0: 104px; --fs-d1: 88px; --fs-d2: 56px; --fs-h1: 40px; --fs-h2: 24px; --fs-h3: 21px;
        --fs-body-lg: 16px; --fs-body: 14px; --fs-body-sm: 13px; --fs-mono: 12px; --fs-mono-sm: 11px; --fs-cap: 9px;
      }
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0; background: var(--bg); color: var(--ink); font-family: var(--sans);
        -webkit-font-smoothing: antialiased; line-height: 1.5; overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }
      ::selection { background: var(--accent-soft); color: var(--accent-hi); }

      .wrap { max-width: var(--page); margin: 0 auto; padding: 0 var(--sp-3xl); }
      .mono { font-family: var(--mono); }
      .eyebrow { font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); }
      .serif { font-family: var(--serif); font-weight: 400; letter-spacing: -0.025em; }
      .ital { font-style: italic; color: var(--accent); }
      .brand .word .ital { font-style: normal; }

      /* dimension-line divider */
      .dim { display: flex; align-items: center; gap: 0; width: 100%; color: var(--ink-dim); }
      .dim .tick { width: 1px; height: 9px; background: var(--line); }
      .dim .rule { flex: 1; height: 1px; background: var(--line); }
      .dim .label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.16em; color: var(--ink-muted); padding: 0 12px; white-space: nowrap; }

      /* sticky blurred nav */
      header.nav { position: sticky; top: 0; z-index: 50; background: rgba(14,14,17,0.82); backdrop-filter: blur(12px); border-bottom: 1px solid var(--line-soft); }
      .nav .row { display: flex; align-items: center; gap: 28px; height: 64px; }
      .brand { display: flex; align-items: center; gap: 9px; }
      .brand .word { font-family: var(--arch); font-size: 20px; text-transform: uppercase; letter-spacing: 0.02em; line-height: 1; color: var(--ink); }
      .nav-links { display: flex; gap: 22px; flex: 1; }
      .nav-links a { font-size: 13.5px; color: var(--ink-soft); transition: color .15s; }
      .nav-links a:hover, .nav-links a.active { color: var(--ink); }
      .ver { font-family: var(--mono); font-size: 10.5px; color: var(--ink-muted); letter-spacing: 0.06em; }
      .btn { font-family: var(--sans); font-size: 13.5px; font-weight: 500; padding: 8px 16px; border-radius: 6px; cursor: pointer; border: 1px solid var(--line); background: transparent; color: var(--ink); transition: .15s; display: inline-flex; align-items: center; gap: 6px; }
      .btn:hover { border-color: var(--ink-muted); }
      .btn-primary { background: var(--accent); border-color: var(--accent); color: #160d08; font-weight: 600; }
      .btn-primary:hover { background: var(--accent-hi); border-color: var(--accent-hi); }

      /* auth nav entry points */
      .auth-nav { display: flex; align-items: center; }
      .auth-nav .auth-anon, .auth-nav .auth-user { display: inline-flex; align-items: center; gap: 8px; }
      .auth-nav [hidden] { display: none !important; }
      .acct-chip { max-width: 220px; }
      .acct-chip #acctEmail { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 160px; }
      .acct-dot { width: 7px; height: 7px; border-radius: 999px; background: var(--ok); box-shadow: 0 0 0 3px rgba(126,193,142,0.18); flex: none; }
      @media (max-width: 720px) {
        .auth-nav .auth-user .btn:first-child { display: none; }
        .acct-chip #acctEmail { max-width: 96px; }
      }

      main { display: block; }

      /* footer */
      footer.site { padding: 56px 0 64px; border-top: 1px solid var(--line-soft); }
      .foot { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 32px; }
      .foot .tag { font-family: var(--serif); font-style: italic; font-size: 17px; color: var(--ink-soft); max-width: 320px; line-height: 1.4; margin-top: 14px; }
      .foot .col h5 { font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em; color: var(--ink-muted); margin: 0 0 12px; font-weight: 400; }
      .foot .col a { display: block; font-size: 13.5px; color: var(--ink-soft); padding: 4px 0; transition: color .15s; }
      .foot .col a:hover { color: var(--ink); }
      .foot-base { display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: 44px; padding-top: 24px; border-top: 1px solid var(--line-soft); font-family: var(--mono); font-size: 10.5px; color: var(--ink-muted); letter-spacing: 0.06em; }
      .foot-base code { color: var(--ink-soft); }

      @media (max-width: 980px) {
        .foot { grid-template-columns: 1fr 1fr; }
        .nav-links { display: none; }
      }
    </style>
    <slot name="head" />
    <!-- Auth client in <head>: window.ArchHubAuth MUST be defined before any
         page body script (signin/account/brain) calls it, else the page throws
         "Cannot read properties of undefined (reading 'sendMagicLink')". -->
    <script src="/auth.js" is:inline></script>
  </head>
  <body>
    <!-- NAV -->
    <header class="nav">
      <div class="wrap row">
        <a class="brand" href="/" aria-label="ArchHub home">
          <svg width="26" height="26" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <path d="M10 56 V32 a22 22 0 0 1 44 0 V56" stroke="#d97757" stroke-width="4.5" stroke-linecap="square"/>
            <circle cx="32" cy="22" r="5.2" fill="#0e0e11" stroke="#d97757" stroke-width="2.4"/>
            <circle cx="32" cy="22" r="1.8" fill="#d97757"/>
            <path d="M6 58 H58" stroke="#d97757" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="word">Arch<span class="ital">Hub</span></span>
        </a>
        <nav class="nav-links">
          <a href="/features" class={isActive('/features') ? 'active' : undefined}>Features</a>
          <a href="/gallery" class={isActive('/gallery') ? 'active' : undefined}>Gallery</a>
          <a href="/docs" class={isActive('/docs') ? 'active' : undefined}>Docs</a>
          <a href="/security" class={isActive('/security') ? 'active' : undefined}>Security</a>
          <a href="/pricing" class={isActive('/pricing') ? 'active' : undefined}>Pricing</a>
          <a href="/community" class={isActive('/community') ? 'active' : undefined}>Community</a>
          <a href="/changelog" class={isActive('/changelog') ? 'active' : undefined}>Changelog</a>
          <!-- Shown only when the visitor has a saved cloud token (signed in).
               The static build can't know auth state, so JS unhides it. -->
          <a href="/brain" id="nav-brain" class={isActive('/brain') ? 'active' : undefined} hidden style="display:none">Brain</a>
        </nav>
        <span class="ver">{connectors} connectors · MIT</span>
        <!-- AUTH ENTRY POINTS — wired to the EXISTING cloud auth backend via
             /auth.js (no new auth system). Signed-out shows Sign in + Get
             started; once a session token exists the script below swaps in the
             account chip. Both states are pre-rendered so there is no flash. -->
        <div class="auth-nav" id="authNav">
          <span class="auth-anon">
            <a class="btn" href="/signin">Sign in</a>
            <a class="btn btn-primary" href="/signin?new=1">Get started</a>
          </span>
          <span class="auth-user" hidden>
            <a class="btn" href="https://github.com/Fargaly/ArchHub/releases/latest" rel="noopener">Download</a>
            <a class="btn btn-primary acct-chip" href="/account" id="acctChip" title="Your account">
              <span class="acct-dot"></span><span id="acctEmail">Account</span>
            </a>
          </span>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="site">
      <div class="wrap">
        <div class="foot">
          <div>
            <a class="brand" href="/" aria-label="ArchHub home">
              <svg width="26" height="26" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                <path d="M10 56 V32 a22 22 0 0 1 44 0 V56" stroke="#d97757" stroke-width="4.5" stroke-linecap="square"/>
                <circle cx="32" cy="22" r="5.2" fill="#0e0e11" stroke="#d97757" stroke-width="2.4"/>
                <circle cx="32" cy="22" r="1.8" fill="#d97757"/>
                <path d="M6 58 H58" stroke="#d97757" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <span class="word">Arch<span class="ital">Hub</span></span>
            </a>
            <div class="tag">A drafting table for AI. Built in the open. MIT, forever.</div>
          </div>
          <div class="col">
            <h5>PRODUCT</h5>
            <a href="/features">Features</a>
            <a href="/gallery">Gallery</a>
            <a href="/docs">Docs</a>
            <a href="/pricing">Pricing</a>
            <a href="/changelog">Changelog</a>
          </div>
          <div class="col">
            <h5>COMPANY</h5>
            <a href="/community">Community</a>
            <a href="/security">Security</a>
            <a href="https://github.com/Fargaly/ArchHub" rel="noopener">GitHub</a>
          </div>
          <div class="col">
            <h5>OPEN</h5>
            <a href="https://github.com/Fargaly/ArchHub" rel="noopener">Source · MIT</a>
            <a href="/community">Discord</a>
            <a href="/changelog">Roadmap</a>
          </div>
        </div>
        <div class="foot-base">
          <span>© 2026 ARCHHUB · MIT LICENSE · {connectors} connectors · {operations} operations</span>
          <span>BUILT FROM COMMIT <code>{sha}</code> · {builtDate}</span>
          <span>DRAFTED, NOT GENERATED ★</span>
        </div>
      </div>
    </footer>
    <!-- Nav state: reflects signed-in (account chip from /v1/me) + reveals the
         Brain link. window.ArchHubAuth is loaded in <head> (one token key). -->
    <script is:inline>
      (function () {
        var A = window.ArchHubAuth;
        // Brain nav link — only needs a valid session (the shared client's
        // token), so a user who signed in anywhere on the site sees it.
        try {
          if (A && A.isSignedIn && A.isSignedIn()) {
            var brn = document.getElementById('nav-brain');
            if (brn) { brn.hidden = false; brn.style.display = ''; }
          }
        } catch (e) {}
        var nav = document.getElementById('authNav');
        if (!A || !nav) return;
        var anon = nav.querySelector('.auth-anon');
        var user = nav.querySelector('.auth-user');
        function show(signedIn) {
          anon.hidden = signedIn;
          user.hidden = !signedIn;
        }
        if (!A.isSignedIn()) { show(false); return; }
        // Have a token — optimistically show the chip, then confirm + fill the
        // email. A dead token (401) is cleared by me() and we fall back to anon.
        show(true);
        A.me().then(function (m) {
          if (!m) { show(false); return; }
          var el = document.getElementById('acctEmail');
          if (el && m.email) el.textContent = m.email;
        });
      })();
    </script>
  </body>
</html>
