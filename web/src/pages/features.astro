---
import Base from '../layouts/Base.astro';
// Connector + operation counts come from the committed build-info.json,
// derived from the REAL app/connectors/ source by scripts/build-info.js
// (npm run refresh-content). No hand-typed, drift-prone numbers.
import buildInfo from '../data/build-info.json';
const connectors = buildInfo.connectors ?? 0;
const operations = buildInfo.operations ?? 0;

// REAL product capabilities — the things ArchHub actually does, mirrored from
// the app's architecture (CLAUDE.md ARCHITECTURE LOCK + the connector contract)
// and the home page. NOT the brain's internal test skills.
const capabilities = [
  {
    glyph: '◈',
    cat: 'THE SURFACE',
    title: 'Graph-first canvas',
    body: 'Every action is a node; every node is replayable. Wire hosts, AI turns, filters, and connector ops together. Drag a parameter and the chain downstream re-cooks — nothing happens that you can\'t see, trace, or undo.',
  },
  {
    glyph: '✎',
    cat: 'THE HAND',
    title: 'The composer drives the graph',
    body: 'Talk to the project. The AI proposes edits to the graph and you approve the line before it\'s drawn. Plan mode gates every write by default; Auto reads freely; YOLO runs everything (opt-in, reversible). Review is the default, not an afterthought.',
  },
  {
    glyph: '⌗',
    cat: 'THE HOSTS',
    title: `${connectors} host connectors`,
    body: `One canvas drives the tools you already use — Revit, AutoCAD, Rhino, 3ds Max, Blender, Speckle, Excel, Word, PowerPoint, Outlook, Notion, Procore and more. ${connectors} connectors, ${operations} typed operations, all behind one uniform contract.`,
  },
  {
    glyph: '↻',
    cat: 'RESILIENCE',
    title: 'Self-healing connectors',
    body: 'No "please relaunch Revit." The connector watches the host, reconnects on its own when a handshake times out, and rebinds the session — and the Self-Heal Inspector shows you the recovery as a live timeline. Honest status throughout: live / loaded / unauthorized / missing, never fabricated data.',
  },
  {
    glyph: '❖',
    cat: 'THE MEMORY',
    title: 'Brain + memory',
    body: 'Persistent memory and reusable skills that grow with your firm. Save any thread as a Skill — plain JSON you own, versioned in your own repo. The brain remembers your standards and reuses them on the next project. Cross-device sync keeps it with you.',
  },
  {
    glyph: '⚿',
    cat: 'LOCAL-FIRST',
    title: 'Local-first, bring-your-own-key',
    body: 'The canvas, the graph, and your files stay on your machine unless you wire an output that says otherwise. Point ArchHub at your own model provider — Anthropic, OpenAI, Google — or a local Ollama. We never see your prompts, your drawings, or your bill.',
  },
  {
    glyph: '◇',
    cat: 'OFFLINE BY DEFAULT',
    title: 'Offline Speckle wires',
    body: 'Every wire is a Speckle send/receive segment with a local disk transport at .speckle/ — no server, no Docker, no account required. Versions are immutable and content-addressed, so undo is just receiving a previous version. Cloud Speckle is opt-in for collaboration.',
  },
  {
    glyph: '⌥',
    cat: 'YOUR CALL',
    title: 'Runs with — or without — an agent',
    body: 'The canvas is fully editable by hand: right-click, drag-rewire, inline param edits, multi-select and group. Let the composer do the work, or build the graph yourself node by node. The AI complements the canvas; it never replaces direct control.',
  },
];
---
<Base title="Features" description="What ArchHub actually does: a graph-first canvas, a composer that drives the graph, 19 self-healing host connectors, a brain you own, and local-first BYO-key AI.">

  <!-- ════════ HEADER ════════ -->
  <section class="fhead">
    <div class="wrap">
      <div class="eyebrow">● What ArchHub does</div>
      <h1 class="title serif">Every tool you use,<br/><span class="ital">on one canvas.</span></h1>
      <p class="lede">ArchHub is a graph-first AI workspace for AEC. Wire the apps you already run, let the composer propose the edits, and keep every step as a node you can replay, audit, and undo.</p>
      <div class="cta-row">
        <a class="btn btn-primary lg" href="https://github.com/Fargaly/ArchHub/releases/latest" rel="noopener">Download for Windows ↓</a>
        <a class="btn lg" href="/changelog">See what shipped →</a>
      </div>
    </div>
  </section>

  <!-- ════════ CAPABILITY GRID ════════ -->
  <section class="sec wrap">
    <div class="caps">
      {capabilities.map((c) => (
        <div class="cap">
          <div class="glyph">{c.glyph}</div>
          <div class="pn">{c.cat}</div>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ════════ CLOSING ════════ -->
  <section class="closing">
    <div class="wrap">
      <div class="eyebrow" style="margin-bottom:20px;">Free in open beta</div>
      <h2 class="serif">Wire your<br/><span class="ital">first host.</span></h2>
      <p>Download, point it at one app, and watch a node light up live. No credit card, MIT license, your keys and your work stay yours.</p>
      <div class="cta-row" style="justify-content:center;">
        <a class="btn btn-primary lg" href="https://github.com/Fargaly/ArchHub/releases/latest" rel="noopener">Download for Windows ↓</a>
        <a class="btn lg" href="/security">Read the security model →</a>
      </div>
    </div>
  </section>

  <style>
    .sec { padding: var(--sp-6xl) 0; }
    .fhead { padding: var(--sp-7xl) 0 var(--sp-5xl); border-bottom: 1px solid var(--line-soft);
      background-image: radial-gradient(var(--line-soft) 1px, transparent 1px); background-size: 22px 22px; }
    h1.title { font-size: var(--fs-d1); line-height: 0.9; letter-spacing: -0.04em; margin: 14px 0 0; }
    .lede { font-family: var(--serif); font-size: var(--fs-h2); font-style: italic; color: var(--ink-soft);
      letter-spacing: -0.01em; line-height: 1.38; margin-top: var(--sp-xl); max-width: 600px; }
    .cta-row { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
    .btn.lg { padding: 11px 20px; font-size: 14.5px; }

    .caps { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; }
    .cap { padding: 32px 30px 34px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .cap:nth-child(2n) { border-right: 0; }
    .cap:nth-last-child(-n+2):nth-child(2n+1), .cap:last-child { }
    .cap .glyph { font-family: var(--serif); font-size: 40px; color: var(--accent); line-height: 1; }
    .cap .pn { font-family: var(--mono); font-size: 10px; color: var(--ink-muted); letter-spacing: 0.18em; margin-top: 16px; }
    .cap h3 { font-family: var(--serif); font-size: 27px; letter-spacing: -0.02em; font-weight: 400; margin: 6px 0 10px; }
    .cap p { font-size: 14px; color: var(--ink-soft); line-height: 1.6; margin: 0; }

    .closing { padding: 110px 0; text-align: center; border-top: 1px solid var(--line-soft);
      background-image: radial-gradient(var(--line-soft) 1px, transparent 1px); background-size: 22px 22px; }
    .closing h2 { font-size: var(--fs-d2); line-height: 0.95; letter-spacing: -0.04em; margin: 0 0 12px; font-weight: 400; }
    .closing p { font-family: var(--serif); font-style: italic; font-size: 21px; color: var(--ink-soft); margin: 0 auto 30px; max-width: 560px; }

    @media (max-width: 820px) {
      h1.title { font-size: 60px; }
      .caps { grid-template-columns: 1fr; }
      .cap { border-right: 0; }
      .closing h2 { font-size: 48px; }
    }
  </style>
</Base>
