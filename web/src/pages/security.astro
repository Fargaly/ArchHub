---
import Base from '../layouts/Base.astro';
---
<Base title="Security" description="ArchHub is local-first. Your projects, your brain, your keys live on your machine. The cloud holds references, never resolved secrets or drawings.">

  <!-- ════════ HEADER ════════ -->
  <section class="shead">
    <div class="wrap">
      <div class="eyebrow">● Security</div>
      <h1 class="title serif">Your work happens here.<br/><span class="ital">Your knowledge stays yours.</span></h1>
      <p class="lede">ArchHub is a desktop application. Your projects, your brain, and your skills live on your machine. The cloud is opt-in for collaboration and billing — and even then it holds references, never resolved secrets.</p>
    </div>
  </section>

  <!-- ════════ THREE CARDS ════════ -->
  <section class="sec wrap">
    <div class="sec-cards">
      <div class="scard">
        <div class="si">⌂</div>
        <h4>Runs on your machine</h4>
        <p>The canvas, the graph, and your files never leave your desktop unless you wire an output that says so. No silent uploads.</p>
      </div>
      <div class="scard">
        <div class="si">⚿</div>
        <h4>Bring your own key</h4>
        <p>Point ArchHub at your own model provider — or a local Ollama. We never see your prompts, your drawings, or your bill.</p>
      </div>
      <div class="scard">
        <div class="si">&#123; &#125;</div>
        <h4>Open by license</h4>
        <p>MIT desktop client, auditable connectors. If you can't read what a node does, it doesn't belong on your canvas.</p>
      </div>
    </div>
  </section>

  <div class="wrap"><div class="dim"><span class="tick"></span><span class="rule"></span><span class="label">WHAT LIVES WHERE</span><span class="rule"></span><span class="tick"></span></div></div>

  <!-- ════════ DATA TABLE ════════ -->
  <section class="sec wrap">
    <div class="split">
      <div>
        <div class="eyebrow">Data residency</div>
        <h2 class="serif split-h">References travel. <span class="ital">Secrets don't.</span></h2>
        <ul class="feat-list">
          <li><span class="fi">⌂</span><span class="ft"><b>On your machine</b><span>brain.db (skills + facts), .speckle/ commits (project state), and 1Password / Windows Credential Manager references to your API keys.</span></span></li>
          <li><span class="fi">☁</span><span class="ft"><b>On the cloud (Fly.io), opt-in</b><span>Identity, plan tier, firm membership, billing state, and a per-user brain replica synced via CRDT — references only, no PII bodies.</span></span></li>
          <li><span class="fi">⊘</span><span class="ft"><b>Never on the cloud</b><span>Resolved API keys, project drawings, and full chat transcripts (unless you opt in to telemetry).</span></span></li>
        </ul>
      </div>
      <div>
        <pre class="skill"><span class="pun">&#123;</span>
  <span class="key">"local"</span><span class="pun">:</span> <span class="pun">[</span><span class="str">"brain.db"</span><span class="pun">,</span> <span class="str">".speckle/"</span><span class="pun">,</span> <span class="str">"key refs"</span><span class="pun">]</span><span class="pun">,</span>
  <span class="key">"cloud"</span><span class="pun">:</span> <span class="pun">[</span><span class="str">"identity"</span><span class="pun">,</span> <span class="str">"plan"</span><span class="pun">,</span>
    <span class="str">"brain replica · refs only"</span><span class="pun">]</span><span class="pun">,</span>
  <span class="key">"never"</span><span class="pun">:</span> <span class="pun">[</span><span class="str">"resolved keys"</span><span class="pun">,</span>
    <span class="str">"drawings"</span><span class="pun">,</span> <span class="str">"transcripts"</span><span class="pun">]</span><span class="pun">,</span>
  <span class="key">"delete"</span><span class="pun">:</span> <span class="str">"Settings → Account · one button"</span>
<span class="pun">&#125;</span></pre>
        <div class="mono note">SECRETS ARE op:// REFERENCES · RESOLVED LOCALLY AT CALL TIME</div>
      </div>
    </div>
  </section>

  <!-- ════════ TRUST + COMPLIANCE ════════ -->
  <section class="sec-dark">
    <div class="wrap sec secpad">
      <div class="eyebrow" style="margin-bottom:14px;">Trust + compliance</div>
      <h2 class="serif" style="font-size:42px; line-height:1; margin:0;">Honest answers, <span class="ital">in the repo.</span></h2>
      <p class="darklede">The full statement lives in <code>TRUST_CENTER.md</code> and <code>CAIQ_LITE.md</code> in the source tree — copy-paste them straight into a vendor security review.</p>
      <ul class="feat-list">
        <li><span class="fi">⌦</span><span class="ft"><b>One-button delete</b><span>GDPR delete is one operation in Settings → Account: your cloud brain replica is purged immediately and your auth tokens are invalidated.</span></span></li>
        <li><span class="fi">◷</span><span class="ft"><b>Local-first by default</b><span>Nothing syncs to the cloud unless you sign in and opt in. The app is fully usable with no account at all.</span></span></li>
      </ul>
      <p style="margin-top:24px;"><a class="ilink" href="https://github.com/Fargaly/ArchHub" rel="noopener">Read the source on GitHub →</a></p>
    </div>
  </section>

  <style>
    .sec { padding: var(--sp-6xl) 0; }
    .shead { padding: var(--sp-7xl) 0 var(--sp-5xl); border-bottom: 1px solid var(--line-soft);
      background-image: radial-gradient(var(--line-soft) 1px, transparent 1px); background-size: 22px 22px; }
    h1.title { font-size: var(--fs-d2); line-height: 1; letter-spacing: -0.035em; margin: 14px 0 0; }
    .lede { font-family: var(--serif); font-size: var(--fs-h2); font-style: italic; color: var(--ink-soft);
      letter-spacing: -0.01em; line-height: 1.38; margin-top: var(--sp-xl); max-width: 640px; }

    .sec-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
    .scard { background: var(--bg-panel); border: 1px solid var(--line); border-radius: 10px; padding: 24px; }
    .scard .si { font-family: var(--serif); font-size: 34px; color: var(--accent); line-height: 1; }
    .scard h4 { font-family: var(--serif); font-size: 23px; letter-spacing: -0.018em; font-weight: 400; margin: 14px 0 8px; }
    .scard p { font-size: 13.5px; color: var(--ink-soft); line-height: 1.55; margin: 0; }

    .split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4xl); align-items: center; }
    .split-h { font-size: 40px; line-height: 1.04; letter-spacing: -0.03em; margin: 14px 0 0; }
    .feat-list { list-style: none; padding: 0; margin: var(--sp-xl) 0 0; }
    .feat-list li { display: flex; gap: 14px; padding: var(--sp-lg) 0; border-top: 1px solid var(--line); }
    .feat-list li .fi { font-family: var(--serif); font-size: 22px; color: var(--accent); font-style: italic; min-width: 30px; }
    .feat-list li .ft b { font-family: var(--sans); font-size: 15px; font-weight: 600; color: var(--ink); display: block; margin-bottom: 3px; }
    .feat-list li .ft span { font-size: 13.5px; color: var(--ink-soft); line-height: 1.55; }
    .ilink { color: var(--accent); font-size: 14px; font-weight: 500; }
    .ilink:hover { color: var(--accent-hi); }

    .skill { background: var(--bg-deep); border: 1px solid var(--line); border-radius: 10px; padding: 20px 22px;
      font-family: var(--mono); font-size: 12.5px; line-height: 1.75; color: var(--ink-soft); margin: 0; white-space: pre-wrap; overflow-x: auto; }
    .skill .key { color: var(--cyan); } .skill .str { color: var(--ok); } .skill .pun { color: var(--ink-muted); }
    .note { font-size: 10px; color: var(--ink-muted); letter-spacing: 0.1em; margin-top: 10px; }

    .sec-dark { background: var(--bg-deep); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .secpad { padding: 80px 0; }
    .darklede { font-family: var(--serif); font-style: italic; font-size: 19px; color: var(--ink-soft); margin: 16px 0 0; max-width: 600px; line-height: 1.4; }
    .darklede code, .sec-dark code { font-family: var(--mono); font-size: 13px; color: var(--accent); font-style: normal; }

    @media (max-width: 820px) {
      h1.title { font-size: 42px; }
      .sec-cards { grid-template-columns: 1fr; }
      .split { grid-template-columns: 1fr; }
    }
  </style>
</Base>
