/* ArchHub theme — Anthropic palette + typography.
   Brand reference (anthropic-skills:brand-guidelines):
     Dark      #141413   primary text + dark surfaces
     Light     #faf9f5   light text
     Mid gray  #b0aea5   secondary text / borders
     Light gr  #e8e6dc   subtle backgrounds
     Orange   #d97757   primary accent
     Blue     #6a9bcc   secondary accent
     Green    #788c5d   tertiary accent (success)
   Typography:
     Headings ≥ 24px → Poppins (Arial fallback)
     Body              → Lora (Georgia fallback)
   Qt6 QSS doesn't support backdrop-filter; the layered look is built
   from semi-transparent fills + 1px highlight strokes over a warm
   near-black canvas.
*/

/* ── Base canvas: Anthropic warm dark ──────────────────────────────────── */
QMainWindow, QWidget#centralWidget, QWidget {
    background-color: #141413;
    color: #faf9f5;
    font-family: "Lora", "Georgia", serif;
    font-size: 14px;
}

QMainWindow {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0    #1a1a18,
        stop:0.5  #141413,
        stop:1    #0f0f0e
    );
}

/* ── Header ───────────────────────────────────────────────────────────── */
QFrame#header {
    background-color: rgba(20, 20, 19, 0.85);
    border: none;
    border-bottom: 1px solid rgba(232, 230, 220, 0.06);
}
QLabel#brand {
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.2px;
    color: #faf9f5;
    padding-left: 4px;
}

/* Model picker — pill */
QComboBox#modelPicker {
    background-color: rgba(232, 230, 220, 0.05);
    color: #faf9f5;
    border: 1px solid rgba(232, 230, 220, 0.10);
    border-radius: 999px;
    padding: 7px 16px;
    min-width: 240px;
    font-size: 13px;
    font-family: "Lora", "Georgia", serif;
}
QComboBox#modelPicker:hover {
    background-color: rgba(232, 230, 220, 0.08);
    border-color: rgba(232, 230, 220, 0.16);
}
QComboBox#modelPicker:focus { border-color: #d97757; }
QComboBox#modelPicker::drop-down { border: none; width: 18px; }
QComboBox QAbstractItemView {
    background-color: #1c1c1a;
    border: 1px solid rgba(232, 230, 220, 0.10);
    selection-background-color: rgba(217, 119, 87, 0.22);
    color: #faf9f5;
    padding: 4px;
    outline: 0;
}

/* Cog menu button */
QToolButton#menuButton {
    background-color: rgba(232, 230, 220, 0.05);
    color: #b0aea5;
    border: 1px solid rgba(232, 230, 220, 0.10);
    border-radius: 999px;
    font-size: 16px;
}
QToolButton#menuButton:hover {
    background-color: rgba(232, 230, 220, 0.10);
    border-color: rgba(232, 230, 220, 0.18);
    color: #faf9f5;
}
QToolButton#menuButton::menu-indicator { image: none; width: 0px; }

/* App menu */
QMenu#appMenu, QMenu {
    background-color: #1c1c1a;
    color: #e8e6dc;
    border: 1px solid rgba(232, 230, 220, 0.10);
    border-radius: 12px;
    padding: 6px;
    font-size: 13px;
}
QMenu#appMenu::item, QMenu::item {
    padding: 8px 18px 8px 14px;
    border-radius: 8px;
    margin: 1px 2px;
    min-width: 220px;
}
QMenu#appMenu::item:selected, QMenu::item:selected {
    background-color: rgba(217, 119, 87, 0.18);
    color: #faf9f5;
}
QMenu::separator {
    height: 1px;
    background: rgba(232, 230, 220, 0.06);
    margin: 4px 8px;
}

/* ── Conversation area — transparent ──────────────────────────────────── */
QScrollArea#conversationScroll, QScrollArea#conversationScroll > QWidget > QWidget {
    background: transparent;
    border: none;
}

/* Welcome card */
QFrame#welcomeCard {
    background-color: rgba(232, 230, 220, 0.04);
    border: 1px solid rgba(232, 230, 220, 0.08);
    border-radius: 22px;
}
QLabel#welcomeTitle {
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 28px;
    font-weight: 600;
    color: #faf9f5;
    letter-spacing: -0.5px;
}
QLabel#welcomeSubtitle {
    color: #b0aea5;
    font-size: 14px;
    line-height: 1.6;
}

/* Quick-start chips */
QPushButton#welcomeChip {
    background-color: rgba(232, 230, 220, 0.04);
    color: #e8e6dc;
    border: 1px solid rgba(232, 230, 220, 0.08);
    border-radius: 14px;
    padding: 12px 16px;
    font-size: 12px;
    text-align: left;
    font-family: "Lora", "Georgia", serif;
}
QPushButton#welcomeChip:hover {
    background-color: rgba(232, 230, 220, 0.08);
    border-color: rgba(217, 119, 87, 0.32);
    color: #faf9f5;
}

/* ── Chat bubbles ─────────────────────────────────────────────────────── */
QFrame#userBubble {
    background-color: rgba(217, 119, 87, 0.14);
    border: 1px solid rgba(217, 119, 87, 0.30);
    border-radius: 22px;
    border-bottom-right-radius: 8px;
}
QFrame#assistantBubble {
    background-color: rgba(232, 230, 220, 0.04);
    border: 1px solid rgba(232, 230, 220, 0.10);
    border-radius: 22px;
    border-bottom-left-radius: 8px;
}

QLabel#typingIndicator {
    color: rgba(250, 249, 245, 0.45);
    font-size: 18px;
    letter-spacing: 4px;
    padding: 2px 4px;
}
QTextEdit#messageText {
    background-color: transparent;
    color: #faf9f5;
    border: none;
    font-family: "Lora", "Georgia", serif;
    font-size: 14px;
    line-height: 1.6;
}

/* ── Tool cards ───────────────────────────────────────────────────────── */
QFrame#toolCard {
    background-color: rgba(15, 15, 14, 0.55);
    border: 1px solid rgba(232, 230, 220, 0.06);
    border-radius: 12px;
}
QFrame#toolCard:hover { border-color: rgba(232, 230, 220, 0.14); }
QLabel#toolCardTitle  { color: #e8e6dc; font-size: 12px; font-weight: 500; }
QLabel#toolCardStatus { color: #b0aea5; font-size: 11px; }
QToolButton#toolCardChevron {
    background-color: transparent;
    color: #b0aea5;
    border: none;
    font-size: 12px;
}
QTextEdit#toolCardDetail {
    background-color: rgba(15, 15, 14, 0.85);
    color: #b0aea5;
    border: 1px solid rgba(232, 230, 220, 0.04);
    border-radius: 10px;
    font-family: "Cascadia Mono", "Consolas", monospace;
    font-size: 11px;
}

/* ── Input bar ────────────────────────────────────────────────────────── */
QFrame#inputBar {
    background-color: rgba(20, 20, 19, 0.78);
    border: none;
    border-top: 1px solid rgba(232, 230, 220, 0.06);
}
QLineEdit#inputField {
    background-color: rgba(232, 230, 220, 0.05);
    color: #faf9f5;
    border: 1px solid rgba(232, 230, 220, 0.12);
    border-radius: 18px;
    padding: 14px 20px;
    font-family: "Lora", "Georgia", serif;
    font-size: 14px;
}
QLineEdit#inputField:hover {
    background-color: rgba(232, 230, 220, 0.08);
    border-color: rgba(232, 230, 220, 0.18);
}
QLineEdit#inputField:focus {
    border-color: #d97757;
    background-color: rgba(232, 230, 220, 0.08);
}

/* ── Status bar ───────────────────────────────────────────────────────── */
QFrame#statusBar {
    background-color: rgba(15, 15, 14, 0.55);
    border: none;
    border-top: 1px solid rgba(232, 230, 220, 0.04);
}
QLabel#statusText { color: #b0aea5; font-size: 11px; }

/* ── Buttons ──────────────────────────────────────────────────────────── */
QPushButton#primaryButton {
    background-color: #d97757;
    color: #141413;
    border: none;
    border-radius: 14px;
    padding: 11px 24px;
    font-family: "Poppins", "Arial", sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.2px;
}
QPushButton#primaryButton:hover  { background-color: #e08866; }
QPushButton#primaryButton:pressed { background-color: #c4654a; }
QPushButton#primaryButton:disabled {
    background-color: rgba(217, 119, 87, 0.20);
    color: rgba(250, 249, 245, 0.40);
}

QPushButton#dangerButton {
    background-color: rgba(196, 90, 78, 0.18);
    color: #faf9f5;
    border: 1px solid rgba(196, 90, 78, 0.45);
    border-radius: 14px;
    padding: 10px 22px;
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 13px;
}
QPushButton#dangerButton:hover {
    background-color: rgba(196, 90, 78, 0.30);
}

QPushButton#ghostButton {
    background-color: transparent;
    color: #e8e6dc;
    border: 1px solid rgba(232, 230, 220, 0.14);
    border-radius: 14px;
    padding: 9px 18px;
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 12px;
}
QPushButton#ghostButton:hover {
    background-color: rgba(232, 230, 220, 0.06);
    color: #faf9f5;
    border-color: rgba(217, 119, 87, 0.45);
}

/* ── Settings dialog ──────────────────────────────────────────────────── */
QDialog#settingsDialog, QDialog#panel {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #1a1a18,
        stop:1 #141413
    );
}
QLabel#settingsTitle {
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 24px;
    font-weight: 600;
    color: #faf9f5;
    letter-spacing: -0.3px;
}
QLabel#settingsSubtitle { color: #b0aea5; font-size: 12px; line-height: 1.5; }

QFrame#providerRow {
    background-color: rgba(232, 230, 220, 0.04);
    border: 1px solid rgba(232, 230, 220, 0.08);
    border-radius: 14px;
}
QFrame#providerRow:hover {
    background-color: rgba(232, 230, 220, 0.06);
    border-color: rgba(232, 230, 220, 0.14);
}
QLabel#providerName   { font-size: 13px; font-weight: 500; color: #faf9f5; }
QLabel#providerStatus { font-size: 12px; color: #b0aea5; }
QLabel#providerIcon   {
    color: #d97757;
    font-size: 14px;
    font-weight: 700;
    min-width: 16px;
}

/* ── Generic panels ───────────────────────────────────────────────────── */
QFrame#panelHeader {
    background-color: rgba(232, 230, 220, 0.02);
    border: none;
    border-bottom: 1px solid rgba(232, 230, 220, 0.06);
}
QLabel#panelTitle {
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 24px;
    font-weight: 600;
    color: #faf9f5;
    letter-spacing: -0.3px;
}
QLabel#panelSubtitle { font-size: 13px; color: #b0aea5; }
QFrame#panelFooter {
    background-color: rgba(15, 15, 14, 0.55);
    border: none;
    border-top: 1px solid rgba(232, 230, 220, 0.04);
}

QFrame#connectorRow {
    background-color: rgba(232, 230, 220, 0.04);
    border: 1px solid rgba(232, 230, 220, 0.08);
    border-radius: 14px;
}
QFrame#connectorRow:hover {
    background-color: rgba(232, 230, 220, 0.06);
    border-color: rgba(232, 230, 220, 0.14);
}
QLabel#connectorIcon {
    background-color: rgba(232, 230, 220, 0.08);
    color: #faf9f5;
    font-size: 16px;
    font-weight: 600;
    border-radius: 22px;
    border: 1px solid rgba(232, 230, 220, 0.12);
}
QLabel#connectorName { font-size: 14px; font-weight: 500; color: #faf9f5; }
QLabel#connectorStatus { font-size: 12px; color: #b0aea5; }

/* ── Scrollbars ───────────────────────────────────────────────────────── */
QScrollBar:vertical {
    background-color: transparent;
    width: 10px;
    margin: 4px 0;
}
QScrollBar::handle:vertical {
    background-color: rgba(232, 230, 220, 0.12);
    border-radius: 5px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover { background-color: rgba(217, 119, 87, 0.35); }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical { background: transparent; }

/* ── Parameters sidebar ──────────────────────────────────────────────── */
QWidget#paramsPanel {
    background-color: rgba(15, 15, 14, 0.55);
    border-left: 1px solid rgba(232, 230, 220, 0.04);
}
QFrame#paramsPanelHeader {
    background-color: transparent;
    border-bottom: 1px solid rgba(232, 230, 220, 0.04);
}
QLabel#paramsPanelTitle {
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 15px; font-weight: 600; color: #faf9f5;
}
QLabel#paramsPanelSubtitle { font-size: 11px; color: #b0aea5; }
QLabel#paramsPanelEmpty { color: #b0aea5; font-size: 12px; padding: 32px 24px; }

QFrame#paramRow {
    background-color: rgba(232, 230, 220, 0.04);
    border: 1px solid rgba(232, 230, 220, 0.06);
    border-radius: 12px;
}
QFrame#paramRow:hover { border-color: rgba(232, 230, 220, 0.14); }
QLabel#paramLabel { font-size: 12px; font-weight: 500; color: #e8e6dc; }
QLabel#paramMeta  { font-size: 10px; color: #b0aea5; }
QLabel#paramReadonly {
    font-size: 11px;
    color: #b0aea5;
    font-family: "Cascadia Mono", "Consolas", monospace;
}

/* Sliders */
QSlider::groove:horizontal {
    height: 3px;
    background: rgba(232, 230, 220, 0.10);
    border-radius: 1px;
}
QSlider::handle:horizontal {
    background: #d97757;
    width: 16px;
    height: 16px;
    margin: -7px 0;
    border-radius: 8px;
    border: 2px solid rgba(250, 249, 245, 0.18);
}
QSlider::handle:horizontal:hover { background: #e08866; }
QSlider::sub-page:horizontal { background: #d97757; border-radius: 1px; }

/* Inline numeric inputs */
QDoubleSpinBox, QSpinBox, QLineEdit, QComboBox {
    background-color: rgba(232, 230, 220, 0.04);
    color: #faf9f5;
    border: 1px solid rgba(232, 230, 220, 0.10);
    border-radius: 10px;
    padding: 6px 10px;
    font-size: 12px;
}
QDoubleSpinBox:focus, QSpinBox:focus, QLineEdit:focus, QComboBox:focus {
    border-color: #d97757;
    background-color: rgba(232, 230, 220, 0.06);
}
QComboBox::drop-down { border: 0; width: 18px; }

/* ── Skills panel ─────────────────────────────────────────────────────── */
QTabWidget#skillsTabs::pane {
    border: 1px solid rgba(232, 230, 220, 0.08);
    border-radius: 14px;
    margin-top: -1px;
    background-color: rgba(232, 230, 220, 0.02);
}
QTabWidget#skillsTabs QTabBar::tab {
    background-color: transparent;
    color: #b0aea5;
    padding: 10px 24px;
    margin-right: 2px;
    border: 1px solid rgba(232, 230, 220, 0.06);
    border-bottom: none;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 13px;
}
QTabWidget#skillsTabs QTabBar::tab:selected {
    background-color: rgba(232, 230, 220, 0.04);
    color: #faf9f5;
    border-color: rgba(217, 119, 87, 0.30);
}

QFrame#skillCard {
    background-color: rgba(232, 230, 220, 0.03);
    border: 1px solid rgba(232, 230, 220, 0.08);
    border-radius: 16px;
}
QFrame#skillCard:hover {
    background-color: rgba(232, 230, 220, 0.05);
    border-color: rgba(217, 119, 87, 0.30);
}
QLabel#skillCardTitle {
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 15px; font-weight: 600; color: #faf9f5;
}
QLabel#skillCardIntent { color: #e8e6dc; font-size: 13px; line-height: 1.5; }
QLabel#skillCardTags {
    color: #d97757;
    font-size: 10px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    font-weight: 600;
    font-family: "Poppins", "Arial", sans-serif;
}
QLabel#skillCardSection { color: #b0aea5; font-size: 11px; margin-top: 4px; }
QLabel#skillCardExample { color: #b0aea5; font-size: 12px; font-style: italic; }
QLabel#skillCardStats { color: #b0aea5; font-size: 11px; }
QLabel#skillCardBadge {
    color: #b0aea5;
    font-size: 10px;
    padding: 3px 10px;
    border: 1px solid rgba(232, 230, 220, 0.10);
    border-radius: 9px;
    background-color: rgba(232, 230, 220, 0.03);
    font-family: "Poppins", "Arial", sans-serif;
}
QLabel#panelEmptyState {
    color: #b0aea5;
    font-size: 13px;
    padding: 28px;
    text-align: center;
}

QFrame#skillSuggestionRow { background: transparent; }

/* Update dialog */
QLabel#updateStatus {
    font-family: "Poppins", "Arial", sans-serif;
    font-size: 14px; font-weight: 600; color: #faf9f5;
}
QLabel#updateDetail { font-size: 12px; color: #b0aea5; line-height: 1.5; }

/* Checkboxes + radio */
QCheckBox, QRadioButton {
    color: #e8e6dc;
    spacing: 10px;
    font-size: 13px;
    font-family: "Lora", "Georgia", serif;
}
QCheckBox::indicator, QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 1px solid rgba(232, 230, 220, 0.18);
    background-color: rgba(232, 230, 220, 0.04);
    border-radius: 5px;
}
QRadioButton::indicator { border-radius: 9px; }
QCheckBox::indicator:hover, QRadioButton::indicator:hover {
    border-color: #d97757;
}
QCheckBox::indicator:checked, QRadioButton::indicator:checked {
    background-color: #d97757;
    border-color: #d97757;
}

/* Welcome chip rendering preserves QPushButton typography */
QPushButton { font-family: "Poppins", "Arial", sans-serif; }

/* Tooltips */
QToolTip {
    background-color: #1c1c1a;
    color: #e8e6dc;
    border: 1px solid rgba(232, 230, 220, 0.10);
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 11px;
    font-family: "Lora", "Georgia", serif;
}
