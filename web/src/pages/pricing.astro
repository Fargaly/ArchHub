---
import Base from '../layouts/Base.astro';
import buildInfo from '../data/build-info.json';
const connectors = buildInfo.connectors ?? 0;

// PRICING-STATUS (docs/PRICING_STATUS.md, README.md): ArchHub is in OPEN BETA
// and every shipped feature is free — no credit card, no paywall. Paid tiers
// (Pro / Studio / Enterprise) are PLANNED, not active billing plans. There is
// no working checkout, so this page states the honest current state and points
// at the real installer instead of selling tiers that can't be purchased.
const planned = [
  { name: 'Pro', who: 'individual architect' },
  { name: 'Studio', who: 'a practice / project team' },
  { name: 'Enterprise', who: 'large firm · roles, SSO, audit' },
];
---
<Base title="Pricing" description="ArchHub is free in open beta — every shipped feature, no credit card, no paywall. Download the signed installer and start wiring hosts.">

  <!-- ════════ HEADER ════════ -->
  <section class="phead">
    <div class="wrap">
      <div class="eyebrow">● Pricing</div>
      <h1 class="title serif">Free<br/><span class="ital">in open beta.</span></h1>
      <p class="lede">Every shipped feature is free right now — the app, the {connectors} connectors, the brain, and offline Speckle sync. No credit card, no paywall, no trial clock.</p>
      <div class="cta-row">
        <a class="btn btn-primary lg" href="https://github.com/Fargaly/ArchHub/releases/latest" rel="noopener">Download for Windows ↓</a>
        <a class="btn lg" href="/features">See what it does →</a>
      </div>
      <div class="fineprint">MIT · bring your own key · no credit card · macOS / Linux on the same release page</div>
    </div>
  </section>

  <!-- ════════ WHAT'S FREE ════════ -->
  <section class="sec wrap">
    <div class="eyebrow" style="margin-bottom:10px;">Everything that works today</div>
    <h2 class="serif" style="font-size:var(--fs-d2); line-height:1; margin:0 0 8px;">Free <span class="ital">means free.</span></h2>
    <p class="lede2">No part of the shipped product is behind a paywall during open beta.</p>
    <ul class="free-list">
      <li><span class="fi">◈</span><span class="ft"><b>The full graph-first canvas</b><span>Unlimited nodes, wires, sessions, and replays.</span></span></li>
      <li><span class="fi">⌗</span><span class="ft"><b>All {connectors} host connectors</b><span>Revit, AutoCAD, Rhino, Max, Blender, Speckle, Excel, Office, Outlook, Notion, Procore and more.</span></span></li>
      <li><span class="fi">❖</span><span class="ft"><b>The brain + your skills</b><span>Persistent memory and reusable Skills as plain JSON you own.</span></span></li>
      <li><span class="fi">⚿</span><span class="ft"><b>Bring your own AI key</b><span>Point at your own provider or a local Ollama. We charge nothing for AI and never see your prompts.</span></span></li>
      <li><span class="fi">◇</span><span class="ft"><b>Offline Speckle sync</b><span>Local disk transport — no server, no account required.</span></span></li>
    </ul>
  </section>

  <div class="wrap"><div class="dim"><span class="tick"></span><span class="rule"></span><span class="label">ON THE ROADMAP</span><span class="rule"></span><span class="tick"></span></div></div>

  <!-- ════════ PLANNED TIERS (honest, not for sale yet) ════════ -->
  <section class="sec wrap">
    <div class="eyebrow" style="margin-bottom:10px;">Later</div>
    <h2 class="serif" style="font-size:42px; line-height:1; margin:0 0 8px;">Paid tiers are <span class="ital">planned</span>, not live.</h2>
    <p class="lede2">When billing turns on after beta, paid plans will add team governance and hosted convenience on top of a free base. They are not purchasable today — and the local-first, BYO-key path stays free.</p>
    <div class="tiers">
      {planned.map((t) => (
        <div class="tier">
          <div class="nm">{t.name}</div>
          <div class="pr">Planned</div>
          <div class="who">{t.who}</div>
          <div class="soon">Not active yet — free in beta</div>
        </div>
      ))}
    </div>
    <p class="note mono">Canonical source: docs/PRICING_STATUS.md · plan details subject to change until billing is enabled.</p>
  </section>

  <!-- ════════ CLOSING ════════ -->
  <section class="closing">
    <div class="wrap">
      <div class="eyebrow" style="margin-bottom:20px;">Nothing to buy</div>
      <h2 class="serif">Just <span class="ital">download it.</span></h2>
      <p>The signed installer is on GitHub Releases. Install, wire a host, and you're working in minutes.</p>
      <div class="cta-row" style="justify-content:center;">
        <a class="btn btn-primary lg" href="https://github.com/Fargaly/ArchHub/releases/latest" rel="noopener">Download for Windows ↓</a>
        <a class="btn lg" href="https://github.com/Fargaly/ArchHub" rel="noopener">Read the source →</a>
      </div>
    </div>
  </section>

  <style>
    .sec { padding: var(--sp-6xl) 0; }
    .phead { padding: var(--sp-7xl) 0 var(--sp-5xl); border-bottom: 1px solid var(--line-soft);
      background-image: radial-gradient(var(--line-soft) 1px, transparent 1px); background-size: 22px 22px; }
    h1.title { font-size: var(--fs-d1); line-height: 0.9; letter-spacing: -0.04em; margin: 14px 0 0; }
    .lede { font-family: var(--serif); font-size: var(--fs-h2); font-style: italic; color: var(--ink-soft);
      letter-spacing: -0.01em; line-height: 1.38; margin-top: var(--sp-xl); max-width: 600px; }
    .lede2 { font-family: var(--serif); font-style: italic; font-size: 19px; color: var(--ink-soft); margin: 0 0 22px; max-width: 600px; line-height: 1.4; }
    .cta-row { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
    .btn.lg { padding: 11px 20px; font-size: 14.5px; }
    .fineprint { font-family: var(--mono); font-size: 11px; color: var(--ink-muted); letter-spacing: 0.04em; margin-top: 18px; }

    .free-list { list-style: none; padding: 0; margin: 0; }
    .free-list li { display: flex; gap: 14px; padding: var(--sp-lg) 0; border-top: 1px solid var(--line); }
    .free-list li .fi { font-family: var(--serif); font-size: 22px; color: var(--accent); font-style: italic; min-width: 30px; }
    .free-list li .ft b { font-family: var(--sans); font-size: 15px; font-weight: 600; color: var(--ink); display: block; margin-bottom: 3px; }
    .free-list li .ft span { font-size: 13.5px; color: var(--ink-soft); line-height: 1.55; }

    .tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin: 6px 0 0; }
    .tier { background: var(--bg-panel); border: 1px solid var(--line); border-radius: 12px; padding: 22px; }
    .tier .nm { font-family: var(--serif); font-size: 26px; font-weight: 400; letter-spacing: -0.02em; }
    .tier .pr { font-family: var(--mono); font-size: 12px; color: var(--accent); letter-spacing: 0.08em; margin-top: 6px; text-transform: uppercase; }
    .tier .who { font-size: 13.5px; color: var(--ink-soft); margin-top: 8px; }
    .tier .soon { font-family: var(--mono); font-size: 10.5px; color: var(--ink-muted); margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--line); letter-spacing: 0.04em; }
    .note { font-size: 10.5px; color: var(--ink-muted); letter-spacing: 0.04em; margin-top: 22px; }

    .closing { padding: 110px 0; text-align: center; border-top: 1px solid var(--line-soft);
      background-image: radial-gradient(var(--line-soft) 1px, transparent 1px); background-size: 22px 22px; }
    .closing h2 { font-size: var(--fs-d2); line-height: 0.95; letter-spacing: -0.04em; margin: 0 0 12px; font-weight: 400; }
    .closing p { font-family: var(--serif); font-style: italic; font-size: 21px; color: var(--ink-soft); margin: 0 auto 30px; max-width: 540px; }

    @media (max-width: 820px) {
      h1.title { font-size: 60px; }
      .tiers { grid-template-columns: 1fr; }
      .closing h2 { font-size: 48px; }
    }
  </style>
</Base>
