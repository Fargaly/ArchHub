#!/usr/bin/env bash
# Pre-push guard — second line of defense if pre-commit was bypassed
# (--no-verify) or a foreign branch was force-pushed with .cs edits.
# Inspects every commit being pushed for staged broker edits; rejects
# the push when any are present without ARCHHUB_ALLOW_CS_EDIT=1.

set -euo pipefail

if [[ "${ARCHHUB_ALLOW_CS_EDIT:-0}" == "1" ]]; then
    exit 0
fi

# stdin lines: <local_ref> <local_sha> <remote_ref> <remote_sha>
remote="$1"
url="$2"

while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip branch deletions (local_sha = 40 zeros).
    if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
        continue
    fi

    # Determine the commit range this push INTRODUCES (what's new on the
    # remote), then look for broker .cs edits ONLY within it.
    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
        # New branch on the remote. Inspect only the commits NOT already on the
        # remote's main — a branch cut from upstream (INCLUDING a squashed main
        # that itself contains every .cs) introduces no NEW .cs and must not be
        # flagged. (Bug fixed 2026-06-04: the old `-50 $local_sha` heuristic
        # walked back THROUGH origin/main's squash commit — which touches all
        # .cs — and false-blocked every clean feature-branch first-push.)
        # Fall back to the last-50 heuristic only when there is genuinely no
        # origin/main to diff against (the very first push of the repo).
        base=$(git rev-parse --verify --quiet refs/remotes/origin/main || true)
        if [[ -n "$base" ]]; then
            range_args=("$base..$local_sha")
        else
            range_args=(-50 "$local_sha")
        fi
    else
        range_args=("$remote_sha..$local_sha")
    fi
    cs_changes=$(git log --name-only --pretty=format: "${range_args[@]}" -- \
                 ':(glob)payload/sources/**/*.cs' 2>/dev/null | sort -u | grep -v '^$' || true)

    if [[ -n "$cs_changes" ]]; then
        cat >&2 <<EOF
═══════════════════════════════════════════════════════════════════════
  PUSH BLOCKED — $local_ref carries broker .cs edits
═══════════════════════════════════════════════════════════════════════
Files touched in commits being pushed:
$(echo "$cs_changes" | sed 's/^/  /')

Founder mandate (AGENTS.md): broker .cs needs AgDR + sign-off.
Bypass: ARCHHUB_ALLOW_CS_EDIT=1 git push ...
═══════════════════════════════════════════════════════════════════════
EOF
        exit 1
    fi
done

# ─────────────────────────────────────────────────────────────────────────
# AgDR-0050 — no-brain-on-commit floor (ADDITIVE; runs AFTER the .cs guard).
# Second line for the brain gate too, mirroring pre-commit. At push time there
# is no staged index, so brain_commit_gate.py (which reads `git diff --cached`)
# normally finds nothing staged and SKIPS (exit 0) — the commit-time hook is
# where this gate really bites. It is wired here for parity + WARN-mode
# completeness; it still warns by default and only blocks on the explicit
# ARCHHUB_BRAIN_COMMIT_GATE=block opt-in. Default is WARN
# (ARCHHUB_BRAIN_COMMIT_GATE unset/warn). Fail-open is absolute: a missing
# python, an absent gate file, or any invocation error must NOT block the push.
PYTHON_BIN="${ARCHHUB_PYTHON:-python}"
if command -v "$PYTHON_BIN" >/dev/null 2>&1 \
   && [ -f tools/brain_commit_gate.py ]; then
    GATE_RC=0
    "$PYTHON_BIN" tools/brain_commit_gate.py || GATE_RC=$?
    if [ "$GATE_RC" = "1" ]; then
        exit 1
    fi
else
    echo "[brain-commit-gate] python or gate script unavailable — fail-open, not blocking." >&2
fi

exit 0
