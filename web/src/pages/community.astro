---
import Base from '../layouts/Base.astro';

// Community / federation status — DATA-DRIVEN from committed JSON, never a
// hardcoded leaderboard.
//   - contributors.json: who has published to the community scope (derived from
//     real reputation rows + community-skill authorship by tools/export_web_data.py).
//   - skills-export.json: how many skills are in the community scope.
// Refresh both from the live brain with `python tools/export_web_data.py` (or
// `npm run refresh-content`); the deploy build reads them with NO daemon. Real
// contributors → real leaderboard; genuinely 0 → a "be the first" state.
import contributorsData from '../data/contributors.json';
import skillsExport from '../data/skills-export.json';

const contributors = contributorsData.contributors ?? [];
const reputationRows = contributorsData.reputation_rows ?? 0;
const publishedSkills = skillsExport.count ?? 0;
const exportedDate = (contributorsData.exported_at ?? '').slice(0, 10);
---
<Base title="Community" description="Architects sharing skills across the ArchHub federation — who's contributing, the live federation status, and how to take part.">

  <!-- ════════ HEADER ════════ -->
  <section class="chead">
    <div class="wrap">
      <div class="eyebrow">● Community</div>
      <h1 class="title serif">Skills travel<br/><span class="ital">firm to firm.</span></h1>
      <p class="lede">Firms publish reusable skills to a shared community scope and earn reputation when their patterns get reused — all routed through the brain's federation, with PII stripped on the way out. No separate ranking store, no marketplace lock-in.</p>
      <div class="cta-row">
        <a class="btn btn-primary lg" href="https://github.com/Fargaly/ArchHub" rel="noopener">Join on GitHub →</a>
        <a class="btn lg" href="/features">See what it does →</a>
      </div>
    </div>
  </section>

  <!-- ════════ LIVE STATUS ════════ -->
  <section class="sec wrap">
    <div class="eyebrow" style="margin-bottom:10px;">Federation status</div>
    <div class="stat-row">
      <div class="stat"><div class="k">{publishedSkills}</div><div class="v">skill{publishedSkills === 1 ? '' : 's'} published</div><div class="vs">COMMUNITY SCOPE</div></div>
      <div class="stat"><div class="k">{contributors.length}</div><div class="v">contributor{contributors.length === 1 ? '' : 's'}</div><div class="vs">PUBLISHING FIRMS</div></div>
      <div class="stat"><div class="k">{reputationRows}</div><div class="v">reputation row{reputationRows === 1 ? '' : 's'}</div><div class="vs">PEER EXCHANGES</div></div>
    </div>
    <p class="note mono">{exportedDate ? `Live as of ${exportedDate} · exported from the brain federation.` : 'Exported from the brain federation.'}</p>

    <h2 class="serif" style="font-size:36px; margin:48px 0 6px; font-weight:400; letter-spacing:-0.02em;">Contributors</h2>
    {contributors.length === 0 ? (
      <p class="empty">
        No firm has published to the community federation yet — so there is no
        leaderboard to show, and we won't fabricate one. This is the real,
        current state: be the first to promote a skill to the community scope and
        your name appears here.
      </p>
    ) : (
      <>
        <p class="note mono" style="margin-bottom:14px;">
          {reputationRows === 0
            ? 'RANKED BY SKILLS PUBLISHED (NO PEER REPUTATION EXCHANGED YET)'
            : 'RANKED BY COMMUNITY REPUTATION AND SKILLS PUBLISHED'}
        </p>
        <table class="leaderboard">
          <thead>
            <tr>
              <th>#</th>
              <th>Contributor</th>
              <th>Skills</th>
              <th>Honed</th>
              <th>Uses</th>
              {reputationRows > 0 && <th>Reputation</th>}
            </tr>
          </thead>
          <tbody>
            {contributors.map((c, i) => (
              <tr>
                <td>{i + 1}</td>
                <td><strong>{c.contributor}</strong></td>
                <td>{c.published_skills}</td>
                <td>{c.honed_trials ? `${c.honed_passed}/${c.honed_trials}` : '—'}</td>
                <td>{c.success_total ?? 0}</td>
                {reputationRows > 0 && <td>{c.reputation ?? '—'}</td>}
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}
  </section>

  <div class="wrap"><div class="dim"><span class="tick"></span><span class="rule"></span><span class="label">HOW TO CONTRIBUTE</span><span class="rule"></span><span class="tick"></span></div></div>

  <!-- ════════ HOW TO ════════ -->
  <section class="sec wrap">
    <div class="steps">
      <div class="step">
        <div class="sn">01</div>
        <h3>Mint a skill locally</h3>
        <p>The reflexion worker does this automatically when you finish a successful flow — your trace becomes a reusable Skill.</p>
      </div>
      <div class="step">
        <div class="sn">02</div>
        <h3>Promote to community</h3>
        <p>Publish via <code>brain.promote</code>. Redaction strips PII automatically before anything leaves your machine.</p>
      </div>
      <div class="step">
        <div class="sn">03</div>
        <h3>Earn reputation</h3>
        <p>Firms subscribed to your outbox pull the skill on their next poll tick, and every reuse builds your reputation.</p>
      </div>
    </div>
  </section>

  <style>
    .sec { padding: var(--sp-6xl) 0; }
    .chead { padding: var(--sp-7xl) 0 var(--sp-5xl); border-bottom: 1px solid var(--line-soft);
      background-image: radial-gradient(var(--line-soft) 1px, transparent 1px); background-size: 22px 22px; }
    h1.title { font-size: var(--fs-d1); line-height: 0.9; letter-spacing: -0.04em; margin: 14px 0 0; }
    .lede { font-family: var(--serif); font-size: var(--fs-h2); font-style: italic; color: var(--ink-soft);
      letter-spacing: -0.01em; line-height: 1.38; margin-top: var(--sp-xl); max-width: 620px; }
    .cta-row { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
    .btn.lg { padding: 11px 20px; font-size: 14.5px; }

    .stat-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
    .stat { background: var(--bg-panel); border: 1px solid var(--line); border-radius: 12px; padding: 24px; }
    .stat .k { font-family: var(--serif); font-size: 52px; color: var(--accent); letter-spacing: -0.03em; line-height: 1; }
    .stat .v { font-size: 14px; color: var(--ink); margin-top: 8px; }
    .stat .vs { font-family: var(--mono); font-size: 9.5px; color: var(--ink-muted); letter-spacing: 0.1em; margin-top: 3px; }
    .note { font-size: 10.5px; color: var(--ink-muted); letter-spacing: 0.06em; margin-top: 16px; }

    .empty { font-family: var(--serif); font-style: italic; font-size: 18px; color: var(--ink-soft); line-height: 1.5; max-width: 620px; }

    .leaderboard { width: 100%; border-collapse: collapse; margin: 0; font-size: 14px; }
    .leaderboard th, .leaderboard td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--line); }
    .leaderboard th { font-family: var(--mono); color: var(--ink-muted); font-weight: 400; font-size: 10px;
      text-transform: uppercase; letter-spacing: 0.1em; }
    .leaderboard tbody tr:hover { background: var(--bg-panel); }
    .leaderboard strong { color: var(--ink); }

    .steps { display: grid; grid-template-columns: repeat(3,1fr); gap: 0; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; }
    .step { padding: 30px 28px 34px; border-right: 1px solid var(--line); }
    .step:last-child { border-right: 0; }
    .step .sn { font-family: var(--serif); font-size: 40px; color: var(--accent); line-height: 1; }
    .step h3 { font-family: var(--serif); font-size: 25px; font-weight: 400; letter-spacing: -0.02em; margin: 14px 0 10px; }
    .step p { font-size: 14px; color: var(--ink-soft); line-height: 1.6; margin: 0; }
    .step code { font-family: var(--mono); font-size: 12.5px; color: var(--accent); }

    @media (max-width: 820px) {
      h1.title { font-size: 60px; }
      .stat-row, .steps { grid-template-columns: 1fr; }
      .step { border-right: 0; border-bottom: 1px solid var(--line); }
    }
  </style>
</Base>
