---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Docs landing — lists every doc in the `docs` collection (title + blurb +
// link). Order by an optional `order` frontmatter field, then alphabetically by
// title so the list is stable regardless of filename. Real content, generated
// from the committed Markdown under src/content/docs — no hand-typed list.
const docs = (await getCollection('docs')).sort((a, b) => {
  const ao = a.data.order ?? 999;
  const bo = b.data.order ?? 999;
  if (ao !== bo) return ao - bo;
  return a.data.title.localeCompare(b.data.title);
});
---
<Base title="Docs" description="ArchHub user documentation — install and first run, the composer + canvas, connecting your AEC stack, the brain, and your account. Plain-English guides for architects and studios.">

  <!-- ════════ HEADER ════════ -->
  <section class="dhead">
    <div class="wrap">
      <div class="eyebrow">● Documentation</div>
      <h1 class="title serif">Everything in ArchHub,<br/><span class="ital">explained plainly.</span></h1>
      <p class="lede">Guides for architects and studio leads — no developer setup, no jargon. Install the app, drive it with the composer, wire in your tools, and let the brain remember your work.</p>
      <div class="cta-row">
        <a class="btn btn-primary lg" href="https://github.com/Fargaly/ArchHub/releases/latest" rel="noopener">Download for Windows ↓</a>
        <a class="btn lg" href="/features">See the features →</a>
      </div>
    </div>
  </section>

  <!-- ════════ DOC INDEX ════════ -->
  <section class="sec wrap">
    <div class="doc-list">
      {docs.map((doc) => (
        <a class="doc-card" href={`/docs/${doc.id}/`}>
          <div class="dc-arrow">→</div>
          <h3>{doc.data.title}</h3>
          {doc.data.description && <p>{doc.data.description}</p>}
        </a>
      ))}
    </div>
  </section>

  <!-- ════════ CLOSING ════════ -->
  <section class="closing">
    <div class="wrap">
      <div class="eyebrow" style="margin-bottom:20px;">Free in open beta</div>
      <h2 class="serif">Read it, then<br/><span class="ital">wire your first host.</span></h2>
      <p>Download, point ArchHub at one app, and watch a node light up live. No credit card, MIT license, your keys and your work stay yours.</p>
      <div class="cta-row" style="justify-content:center;">
        <a class="btn btn-primary lg" href="https://github.com/Fargaly/ArchHub/releases/latest" rel="noopener">Download for Windows ↓</a>
        <a class="btn lg" href="/security">Read the security model →</a>
      </div>
    </div>
  </section>

  <style>
    .sec { padding: var(--sp-6xl) 0; }
    .dhead { padding: var(--sp-7xl) 0 var(--sp-5xl); border-bottom: 1px solid var(--line-soft);
      background-image: radial-gradient(var(--line-soft) 1px, transparent 1px); background-size: 22px 22px; }
    h1.title { font-size: var(--fs-d1); line-height: 0.9; letter-spacing: -0.04em; margin: 14px 0 0; }
    .lede { font-family: var(--serif); font-size: var(--fs-h2); font-style: italic; color: var(--ink-soft);
      letter-spacing: -0.01em; line-height: 1.38; margin-top: var(--sp-xl); max-width: 620px; }
    .cta-row { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
    .btn.lg { padding: 11px 20px; font-size: 14.5px; }

    .doc-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .doc-card { display: block; position: relative; background: var(--bg-panel); border: 1px solid var(--line);
      border-radius: 12px; padding: 26px 28px 28px; transition: border-color .15s, transform .15s; }
    .doc-card:hover { border-color: var(--accent); transform: translateY(-2px); }
    .doc-card .dc-arrow { position: absolute; top: 22px; right: 24px; font-family: var(--mono); font-size: 18px;
      color: var(--ink-muted); transition: color .15s, transform .15s; }
    .doc-card:hover .dc-arrow { color: var(--accent); transform: translateX(3px); }
    .doc-card h3 { font-family: var(--serif); font-size: 25px; letter-spacing: -0.02em; font-weight: 400;
      margin: 0 56px 10px 0; line-height: 1.12; }
    .doc-card p { font-size: 13.5px; color: var(--ink-soft); line-height: 1.55; margin: 0; }

    .closing { padding: 110px 0; text-align: center; border-top: 1px solid var(--line-soft);
      background-image: radial-gradient(var(--line-soft) 1px, transparent 1px); background-size: 22px 22px; }
    .closing h2 { font-size: var(--fs-d2); line-height: 0.95; letter-spacing: -0.04em; margin: 0 0 12px; font-weight: 400; }
    .closing p { font-family: var(--serif); font-style: italic; font-size: 21px; color: var(--ink-soft); margin: 0 auto 30px; max-width: 560px; }

    @media (max-width: 820px) {
      h1.title { font-size: 60px; }
      .doc-list { grid-template-columns: 1fr; }
      .closing h2 { font-size: 48px; }
    }
  </style>
</Base>
