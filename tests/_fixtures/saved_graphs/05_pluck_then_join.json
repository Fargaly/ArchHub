        {"code": "A-102", "status": "REVISE", "rev": 0},
        {"code": "A-103", "status": "APPROVED", "rev": 1}
      ]},
      "inputs": [],
      "outputs": [
        {"name": "value", "type": "list", "speckle_type": "Objects.Other.List", "description": "", "required": false, "default": null, "exec": false, "multiple": false}
