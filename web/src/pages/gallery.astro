---
import Base from '../layouts/Base.astro';
// Community Gallery — the public face of the self-extension marketplace.
//
// ONE-SYSTEM: this page adds NO new store and NO new auth. It is a thin
// browser client over the EXISTING cloud marketplace endpoints already live in
// cloud_backend/marketplace.py (mounted at root, no prefix):
//   GET  {API}/marketplace/packs?source=&pack_type=&sort=   (browse + filter)
//   POST {API}/marketplace/packs/{id}/vote   {vote:+1|-1|0}  (one per user)
//   POST {API}/marketplace/packs/{id}/promote                (founder-gated)
//   GET  {API}/marketplace/packs/{id}/download               (adopt payload)
// The bearer comes from window.ArchHubAuth (loaded in <head> by Base.astro) —
// the SAME token the rest of the site uses. The in-app desktop gallery is the
// authenticated install surface; this page is the public, on-brand discovery
// face (filter / vote / at-own-risk warning / adopt link).
//
// Founder steer (2026-06-22): user-made + agent-made features published, VOTED
// up/down, top-voted adopt-able officially; SAME channel with a user / agent /
// official FILTER + WARN the user they adopt at their own responsibility.
---
<Base title="Community Gallery" description="Architect- and agent-built features for ArchHub — skills, connectors, nodes, and widgets, voted by the community. Filter by source, vote, and adopt at your own responsibility.">
  <section class="gal-page">
    <div class="wrap">
      <div class="eyebrow">● Community Gallery</div>
      <h1 class="serif gal-h1">Features, <span class="ital">built by the community</span></h1>
      <p class="gal-sub">
        Skills, connectors, nodes, and widgets — published by architects and by
        the ArchHub agent, voted by everyone. The top-voted ones can be promoted
        to official. <strong>Community-made packs are not reviewed by ArchHub —
        you adopt them at your own responsibility.</strong>
      </p>

      <!-- AT-OWN-RISK banner — always visible; the standing community contract. -->
      <div class="gal-risk" role="note">
        <span class="gal-risk-icon" aria-hidden="true">●</span>
        <span>
          <strong>Adopt at your own risk.</strong> User- and agent-made packs are
          community contributions, not vetted by ArchHub. Review what a pack does
          before you install it. Only <em>official</em> packs have been promoted
          by the ArchHub team.
        </span>
      </div>

      <!-- FILTERS — source (user/agent/official/all) + type + sort. -->
      <div class="gal-controls">
        <div class="gal-chips" id="srcChips" role="tablist" aria-label="Filter by source">
          <button class="gal-chip active" data-src="all" type="button">All</button>
          <button class="gal-chip" data-src="user" type="button">User-made</button>
          <button class="gal-chip" data-src="agent" type="button">Agent-made</button>
          <button class="gal-chip" data-src="official" type="button">Official</button>
        </div>
        <div class="gal-chips" id="typeChips" role="tablist" aria-label="Filter by type">
          <button class="gal-chip sm active" data-type="" type="button">Any type</button>
          <button class="gal-chip sm" data-type="skill" type="button">Skill</button>
          <button class="gal-chip sm" data-type="connector" type="button">Connector</button>
          <button class="gal-chip sm" data-type="node" type="button">Node</button>
          <button class="gal-chip sm" data-type="widget" type="button">Widget</button>
        </div>
        <div class="gal-sort">
          <label for="sortSel" class="gal-k">Sort</label>
          <select id="sortSel" class="gal-select">
            <option value="top">Top voted</option>
            <option value="new">Newest</option>
          </select>
        </div>
      </div>

      <div id="galGrid" class="gal-grid" aria-live="polite">
        <div class="gal-loading">Loading the gallery…</div>
      </div>
    </div>
  </section>

  <style>
    .gal-page { padding: 56px 0 96px; }
    .gal-h1 { font-size: 40px; margin: 10px 0 14px; }
    .gal-sub { max-width: 720px; color: var(--ink-soft); font-size: 15px; line-height: 1.6; margin: 0 0 22px; }
    .gal-sub strong { color: var(--ink); }

    .gal-risk { display: flex; gap: 12px; align-items: flex-start; max-width: 820px; background: var(--accent-soft); border: 1px solid var(--accent); border-radius: var(--r-lg); padding: 14px 18px; color: var(--ink); font-size: 13.5px; line-height: 1.55; margin-bottom: 28px; }
    .gal-risk-icon { color: var(--accent-hi); margin-top: 2px; }
    .gal-risk em { color: var(--accent-hi); font-style: normal; }

    .gal-controls { display: flex; flex-wrap: wrap; gap: 16px 24px; align-items: center; margin-bottom: 28px; }
    .gal-chips { display: flex; gap: 8px; flex-wrap: wrap; }
    .gal-chip { font-family: var(--sans); font-size: 13px; font-weight: 500; padding: 7px 14px; border-radius: var(--r-pill); cursor: pointer; border: 1px solid var(--line); background: transparent; color: var(--ink-soft); transition: .14s; }
    .gal-chip.sm { font-size: 12px; padding: 5px 11px; }
    .gal-chip:hover { border-color: var(--ink-muted); color: var(--ink); }
    .gal-chip.active { background: var(--accent); border-color: var(--accent); color: #160d08; font-weight: 600; }
    .gal-sort { display: flex; align-items: center; gap: 8px; margin-left: auto; }
    .gal-k { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); }
    .gal-select { font-family: var(--sans); font-size: 13px; background: var(--bg-panel); color: var(--ink); border: 1px solid var(--line); border-radius: var(--r-md); padding: 7px 10px; cursor: pointer; }

    .gal-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 18px; }
    .gal-loading, .gal-empty { color: var(--ink-soft); font-size: 14px; grid-column: 1 / -1; padding: 24px 0; }
    .gal-empty strong { color: var(--ink); }

    .gal-card { display: flex; flex-direction: column; background: var(--bg-panel); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 20px 20px 16px; transition: border-color .14s; }
    .gal-card:hover { border-color: var(--ink-muted); }
    .gal-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
    .gal-badge { font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 9px; border-radius: var(--r-pill); border: 1px solid var(--line); color: var(--ink-soft); white-space: nowrap; }
    .gal-badge.src-user { color: var(--blue); border-color: var(--blue); }
    .gal-badge.src-agent { color: var(--purple); border-color: var(--purple); }
    .gal-badge.src-official { color: var(--ok); border-color: var(--ok); background: rgba(126,193,142,0.08); }
    .gal-type { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted); }
    .gal-title { font-size: 18px; color: var(--ink); margin: 12px 0 6px; line-height: 1.3; }
    .gal-desc { font-size: 13.5px; color: var(--ink-soft); line-height: 1.55; flex: 1; margin: 0 0 14px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .gal-meta { display: flex; align-items: center; gap: 12px; font-family: var(--mono); font-size: 11px; color: var(--ink-muted); margin-bottom: 14px; }
    .gal-foot { display: flex; align-items: center; gap: 10px; }
    .gal-votes { display: flex; align-items: center; gap: 4px; }
    .gal-vote { font-family: var(--mono); font-size: 14px; line-height: 1; padding: 6px 9px; border-radius: var(--r-md); border: 1px solid var(--line); background: transparent; color: var(--ink-soft); cursor: pointer; transition: .12s; }
    .gal-vote:hover { border-color: var(--ink-muted); color: var(--ink); }
    .gal-vote.up.on { color: var(--ok); border-color: var(--ok); }
    .gal-vote.down.on { color: var(--err); border-color: var(--err); }
    .gal-vote:disabled { opacity: .5; cursor: default; }
    .gal-score { font-family: var(--mono); font-size: 13px; color: var(--ink); min-width: 22px; text-align: center; }
    .gal-adopt { margin-left: auto; }
    .gal-promote { font-size: 12px; padding: 6px 12px; }
    .gal-card-foot-note { font-size: 11.5px; color: var(--ink-muted); margin-top: 10px; }
    .gal-card-foot-note.risk { color: var(--accent-hi); }

    @media (max-width: 620px) {
      .gal-h1 { font-size: 30px; }
      .gal-grid { grid-template-columns: 1fr; }
      .gal-sort { margin-left: 0; }
    }
  </style>

  <!-- Adopt-at-own-risk modal — shown before installing a community pack. -->
  <div id="galModal" class="gal-modal" hidden>
    <div class="gal-modal-card" role="dialog" aria-modal="true" aria-labelledby="galModalTitle">
      <div class="eyebrow">● Adopt at your own risk</div>
      <h2 class="serif" id="galModalTitle">Adopt this <span class="ital">community pack?</span></h2>
      <p id="galModalBody" class="gal-modal-body"></p>
      <div class="gal-modal-actions">
        <button class="btn" id="galModalCancel" type="button">Cancel</button>
        <a class="btn btn-primary" id="galModalConfirm" href="#" rel="noopener" target="_blank">I understand — adopt</a>
      </div>
    </div>
  </div>
  <style>
    .gal-modal { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; background: rgba(10,10,13,0.78); backdrop-filter: blur(4px); padding: 20px; }
    .gal-modal[hidden] { display: none; }
    .gal-modal-card { max-width: 520px; width: 100%; background: var(--bg-panel); border: 1px solid var(--accent); border-radius: var(--r-xl); padding: 28px 30px; }
    .gal-modal-card h2 { font-size: 28px; margin: 8px 0 16px; }
    .gal-modal-body { font-size: 14px; color: var(--ink-soft); line-height: 1.6; margin: 0 0 24px; }
    .gal-modal-body strong { color: var(--ink); }
    .gal-modal-actions { display: flex; gap: 12px; justify-content: flex-end; }
  </style>

  <script is:inline>
    (function () {
      var A = window.ArchHubAuth;
      var API = (A && A.API) || 'https://archhub-cloud.fly.dev';
      var grid = document.getElementById('galGrid');
      var modal = document.getElementById('galModal');
      var state = { source: 'all', type: '', sort: 'top', isAdmin: false };

      function esc(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
        });
      }
      function authHeaders() {
        var t = A && A.getToken && A.getToken();
        return t ? { 'Authorization': 'Bearer ' + t } : {};
      }
      function srcLabel(s) {
        return s === 'agent' ? 'Agent-made' : s === 'official' ? 'Official' : 'User-made';
      }

      // ---- render -----------------------------------------------------------
      function cardHTML(p) {
        var src = p.source || 'user';
        var risk = !!p.at_own_risk;
        var my = p.my_vote || 0;
        var canPromote = state.isAdmin && src !== 'official';
        var dl = API + '/marketplace/packs/' + encodeURIComponent(p.id) + '/download';
        return (
          '<div class="gal-card" data-id="' + esc(p.id) + '" data-risk="' + (risk ? '1' : '0') +
            '" data-title="' + esc(p.title) + '" data-dl="' + esc(dl) + '">' +
            '<div class="gal-card-top">' +
              '<span class="gal-badge src-' + esc(src) + '">' + esc(srcLabel(src)) + '</span>' +
              '<span class="gal-type">' + esc(p.pack_type || 'skill') + '</span>' +
            '</div>' +
            '<div class="gal-title">' + esc(p.title) + '</div>' +
            '<div class="gal-desc">' + esc(p.description || 'No description provided.') + '</div>' +
            '<div class="gal-meta">' +
              '<span>v' + esc(p.version || '0.1.0') + '</span>' +
              '<span>↓ ' + esc(p.download_count != null ? p.download_count : 0) + '</span>' +
            '</div>' +
            '<div class="gal-foot">' +
              '<div class="gal-votes">' +
                '<button class="gal-vote up' + (my === 1 ? ' on' : '') + '" data-vote="1" type="button" aria-label="Vote up">▲</button>' +
                '<span class="gal-score">' + (p.score != null ? p.score : (p.up_votes - p.down_votes)) + '</span>' +
                '<button class="gal-vote down' + (my === -1 ? ' on' : '') + '" data-vote="-1" type="button" aria-label="Vote down">▼</button>' +
              '</div>' +
              '<button class="btn btn-primary gal-adopt" data-adopt="1" type="button">Adopt</button>' +
              (canPromote ? '<button class="btn gal-promote" data-promote="1" type="button">Promote ★</button>' : '') +
            '</div>' +
            (risk
              ? '<div class="gal-card-foot-note risk">Not reviewed by ArchHub — adopt at your own risk.</div>'
              : '<div class="gal-card-foot-note">Official — promoted by the ArchHub team.</div>') +
          '</div>'
        );
      }

      function render(packs) {
        if (!packs || !packs.length) {
          grid.innerHTML = '<div class="gal-empty"><strong>Nothing here yet.</strong> ' +
            'Be the first to publish a pack from the desktop app — it shows up here once approved.</div>';
          return;
        }
        grid.innerHTML = packs.map(cardHTML).join('');
      }

      // ---- load -------------------------------------------------------------
      function load() {
        grid.innerHTML = '<div class="gal-loading">Loading the gallery…</div>';
        var qs = 'verified_only=true&limit=60&sort=' + encodeURIComponent(state.sort) +
                 '&source=' + encodeURIComponent(state.source);
        if (state.type) qs += '&pack_type=' + encodeURIComponent(state.type);
        fetch(API + '/marketplace/packs?' + qs, { headers: authHeaders() })
          .then(function (r) { return r.ok ? r.json() : { packs: [] }; })
          .then(function (d) { render((d && d.packs) || []); })
          .catch(function () {
            grid.innerHTML = '<div class="gal-empty">Could not reach the gallery. Try again shortly.</div>';
          });
      }

      // ---- vote -------------------------------------------------------------
      function castVote(card, dir) {
        if (!A || !A.isSignedIn()) { location.href = '/signin'; return; }
        var id = card.getAttribute('data-id');
        var up = card.querySelector('.gal-vote.up');
        var down = card.querySelector('.gal-vote.down');
        // Toggle off if re-clicking the same direction → vote 0.
        var current = up.classList.contains('on') ? 1 : (down.classList.contains('on') ? -1 : 0);
        var next = (current === dir) ? 0 : dir;
        up.disabled = down.disabled = true;
        fetch(API + '/marketplace/packs/' + encodeURIComponent(id) + '/vote', {
          method: 'POST',
          headers: Object.assign({ 'Content-Type': 'application/json' }, authHeaders()),
          body: JSON.stringify({ vote: next })
        }).then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) {
            up.disabled = down.disabled = false;
            if (!d) return;
            card.querySelector('.gal-score').textContent = (d.up_votes - d.down_votes);
            up.classList.toggle('on', d.my_vote === 1);
            down.classList.toggle('on', d.my_vote === -1);
          }).catch(function () { up.disabled = down.disabled = false; });
      }

      // ---- promote (founder) ------------------------------------------------
      function promote(card) {
        var id = card.getAttribute('data-id');
        var btn = card.querySelector('[data-promote]');
        if (btn) { btn.disabled = true; btn.textContent = 'Promoting…'; }
        fetch(API + '/marketplace/packs/' + encodeURIComponent(id) + '/promote', {
          method: 'POST',
          headers: authHeaders()
        }).then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) { if (d) load(); else if (btn) { btn.disabled = false; btn.textContent = 'Promote ★'; } })
          .catch(function () { if (btn) { btn.disabled = false; btn.textContent = 'Promote ★'; } });
      }

      // ---- adopt (at-own-risk modal) ---------------------------------------
      function adopt(card) {
        var risk = card.getAttribute('data-risk') === '1';
        var title = card.getAttribute('data-title');
        var dl = card.getAttribute('data-dl');
        if (!risk) { window.open(dl, '_blank', 'noopener'); return; }
        var body = document.getElementById('galModalBody');
        var confirm = document.getElementById('galModalConfirm');
        body.innerHTML = '<strong>' + esc(title) + '</strong> is community-made and ' +
          '<strong>has not been reviewed by ArchHub</strong>. By adopting it you take ' +
          'responsibility for what it does on your machine. The desktop app re-verifies ' +
          'the pack signature before installing, but does not audit its behavior.';
        confirm.setAttribute('href', dl);
        modal.hidden = false;
      }
      function closeModal() { modal.hidden = true; }
      document.getElementById('galModalCancel').addEventListener('click', closeModal);
      modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });

      // ---- delegated card events -------------------------------------------
      grid.addEventListener('click', function (e) {
        var card = e.target.closest('.gal-card');
        if (!card) return;
        var voteBtn = e.target.closest('.gal-vote');
        if (voteBtn) { castVote(card, parseInt(voteBtn.getAttribute('data-vote'), 10)); return; }
        if (e.target.closest('[data-adopt]')) { adopt(card); return; }
        if (e.target.closest('[data-promote]')) { promote(card); return; }
      });

      // ---- filter wiring ----------------------------------------------------
      document.getElementById('srcChips').addEventListener('click', function (e) {
        var b = e.target.closest('.gal-chip'); if (!b) return;
        this.querySelectorAll('.gal-chip').forEach(function (c) { c.classList.remove('active'); });
        b.classList.add('active'); state.source = b.getAttribute('data-src'); load();
      });
      document.getElementById('typeChips').addEventListener('click', function (e) {
        var b = e.target.closest('.gal-chip'); if (!b) return;
        this.querySelectorAll('.gal-chip').forEach(function (c) { c.classList.remove('active'); });
        b.classList.add('active'); state.type = b.getAttribute('data-type'); load();
      });
      document.getElementById('sortSel').addEventListener('change', function () {
        state.sort = this.value; load();
      });

      // Resolve admin (founder) once so the Promote action only shows for them,
      // then load. /v1/me returns is_admin for the founder account.
      function boot() {
        if (A && A.isSignedIn()) {
          A.me().then(function (m) {
            state.isAdmin = !!(m && m.is_admin);
            load();
          }).catch(load);
        } else { load(); }
      }
      boot();
    })();
  </script>
</Base>
