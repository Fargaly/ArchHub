# Copy to .env for local dev; set via `flyctl secrets set ...` in prod.

# Domain
PUBLIC_URL=http://localhost:8000

# Stripe (use sk_test_... + whsec_... in dev)
STRIPE_SECRET_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
STRIPE_PRICE_SOLO=price_REPLACE
STRIPE_PRICE_STUDIO=price_REPLACE
STRIPE_PRICE_FIRM=price_REPLACE

# Provider keys — server's own, NOT user-supplied
ANTHROPIC_API_KEY=sk-ant-REPLACE
OPENAI_API_KEY=sk-proj-REPLACE
GOOGLE_API_KEY=AIzaREPLACE

# Magic-link email sender (https://resend.com — $0 dev tier)
# FROM domain must be VERIFIED in Resend. We use the `send.archhub.io`
# subdomain so the parent zone's MX / SPF stay untouched.
RESEND_API_KEY=re_REPLACE
FROM_EMAIL=noreply@send.archhub.io

# ── FREE DEFAULT tier (founder, 2026-06-22 — zero-config, no 402) ─────
# A strong free model served BY OUR cloud to EVERY user with NO BYO key
# and NO paid plan, so the composer works the instant ArchHub installs.
# ON by default; one server-side free-account key serves all users.
FREE_DEFAULT_ENABLED=1
# Provider: groq (default, fast + free Llama/Qwen) | openrouter | google | custom
FREE_PROVIDER=groq
# Model + base URL default per provider; override only if you want a
# different free model. (Groq: llama-3.3-70b-versatile.)
ARCHHUB_FREE_MODEL=llama-3.3-70b-versatile
# FREE_PROVIDER_BASE_URL=https://api.groq.com/openai/v1
#
# THE ONE FOUNDER STEP for zero-config free: create a FREE account at
# https://console.groq.com (or openrouter.ai / aistudio.google.com),
# copy the free API key, and set it as a Fly secret. Until this is set,
# the free tier degrades to the honest BYO 402 (BYO still works) — it
# never crashes. Accepts a raw key OR an op:// reference (resolved at
# launch by the secret shim — never inline the plaintext in git):
#   flyctl secrets set FREE_PROVIDER_API_KEY=gsk_xxx -a archhub-cloud
#   # or:  FREE_PROVIDER_API_KEY=op://archhub/groq/api_key
FREE_PROVIDER_API_KEY=gsk_REPLACE

# Cloud LLM proxy live-switch (founder, 2026-05-24).
# 0 = HOSTED (paid-credit) inference is gated off (default; safe). The
#     FREE DEFAULT tier above is SEPARATE and stays on regardless — a
#     no-key user is served the free model, not a 402.
# 1 = proxy serves Studio+Firm HOSTED plans using the server-side
#     provider keys above. Flip to 1 ONLY after funding upstream provider
#     balances — accidental traffic on 1 burns real $.
PROXY_LIVE=0

# Storage + limits
DATABASE_URL=./archhub_cloud.db
TRIAL_MESSAGES=30
RATE_LIMIT_PER_MIN=30
