# ==== Build artifacts ====
build/
dist/
dist-staging/
*.egg-info/
*.spec

# ==== Bundled runtime (downloaded by installer\build.bat) ====
python/

# ==== Python ====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==== Virtual environments ====
.venv/
venv/
env/
ENV/

# ==== IDE / Editor ====
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==== Secrets ====
*.env
.env.local
secrets.dat
settings.json
state.json
*.log

# ==== Compiled C# binaries (built per-machine via dev kit) ====
**/bin/
**/obj/
*.dll
*.pdb

# ==== Inno Setup output ====
*.iss.bak
ArchHub-Setup*.exe

# ==== Test / temporary outputs ====
/tmp/
*.tmp
build_output.txt
diagnose_output.txt
startup_error.log

# ==== Per-machine build outputs ====
# Source build folders stay ignored (they're per-machine).
payload/sources/*/bin/
payload/sources/*/obj/
# But shipped, prebuilt DLLs in payload/<family>/<year>/ ARE
# checked in so the installer can bundle them — users don't need
# .NET SDK or Developer Pack at setup time.
!payload/revit/
!payload/revit/**
!payload/autocad/
!payload/autocad/**
!payload/max/
!payload/max/**
# Still ignore the per-user .pdb in those dirs (debug-only, big).
payload/revit/**/*.pdb
payload/autocad/**/*.pdb

# ==== Per-user / per-machine app data (lives in %LOCALAPPDATA%) ====
**/skill_usage.json
